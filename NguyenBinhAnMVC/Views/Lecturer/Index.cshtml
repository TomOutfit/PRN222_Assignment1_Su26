@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "News Articles";
    var categories = ViewBag.Categories as IEnumerable<NguyenBinhAn_A01_Data.Models.Category>
                     ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Category>();
}

<style>
    .lecturer-title-section {
        margin-bottom: 30px;
    }
    
    .lecturer-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .search-wrapper-lecturer {
        position: relative;
        max-width: 400px;
        width: 100%;
    }

    .search-wrapper-lecturer .form-control-modern {
        padding-left: 45px;
        border-radius: 12px;
        width: 100%;
    }

    .search-wrapper-lecturer .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 16px;
        pointer-events: none;
    }

    .sidebar-card {
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        overflow: hidden;
        margin-bottom: 25px;
    }

    .sidebar-card-header {
        background: #f8fafc;
        border-bottom: 1.5px solid var(--border-color);
        padding: 18px 24px;
        font-weight: 800;
        font-size: 14.5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .category-list {
        display: flex;
        flex-direction: column;
    }

    .category-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 24px;
        color: #475569;
        text-decoration: none;
        font-size: 14.5px;
        font-weight: 600;
        transition: var(--transition-base);
        border-bottom: 1px solid var(--border-color);
    }

    .category-item:last-child {
        border-bottom: none;
    }

    .category-item:hover, .category-item.active {
        background: rgba(99, 102, 241, 0.05);
        color: #4f46e5;
        padding-left: 30px;
    }

    .category-item .cat-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #cbd5e1;
        transition: var(--transition-base);
    }

    .category-item:hover .cat-dot, .category-item.active .cat-dot {
        background: #4f46e5;
        box-shadow: 0 0 8px rgba(79, 70, 229, 0.5);
    }

    .news-card-lecturer {
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        padding: 28px;
        margin-bottom: 20px;
        transition: var(--transition-base);
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .news-card-lecturer:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 35px rgba(99, 102, 241, 0.06);
        border-color: rgba(99, 102, 241, 0.2);
        color: inherit;
    }

    .news-card-lecturer .card-category {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 14px;
        background: rgba(99, 102, 241, 0.08);
        color: #4f46e5;
    }

    .news-card-lecturer .card-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
        line-height: 1.4;
        letter-spacing: -0.25px;
    }

    .news-card-lecturer:hover .card-title {
        color: #4f46e5;
    }

    .news-card-lecturer .card-headline {
        font-size: 0.95rem;
        color: #475569;
        margin-bottom: 20px;
        line-height: 1.5;
        font-weight: 500;
    }

    .news-card-lecturer .card-meta {
        display: flex;
        align-items: center;
        gap: 16px;
        font-size: 13.5px;
        color: #64748b;
        font-weight: 600;
        border-top: 1px solid var(--border-color);
        padding-top: 18px;
    }

    .news-card-lecturer .card-meta i {
        color: #4f46e5;
    }

    .news-card-lecturer .card-meta .read-more {
        margin-left: auto;
        color: #4f46e5;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition-base);
    }

    .news-card-lecturer:hover .card-meta .read-more {
        transform: translateX(4px);
    }

    .badge-filter {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 12px;
        background: rgba(99, 102, 241, 0.08);
        color: #4f46e5;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 25px;
        border: 1px solid rgba(99, 102, 241, 0.15);
        text-decoration: none;
    }

    .badge-filter .close-btn {
        color: #4f46e5;
        font-size: 16px;
        line-height: 1;
        font-weight: bold;
    }

    .quick-stats-item {
        padding: 14px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border-color);
    }

    .quick-stats-item:last-child {
        border-bottom: none;
    }

    .quick-stats-item span {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
    }

    .quick-stats-item strong {
        font-weight: 800;
        color: #0f172a;
        font-size: 15px;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="lecturer-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1><i class="bi bi-mortarboard-fill me-3 text-primary"></i>News Articles</h1>
                <p class="text-muted font-weight-semibold mb-0 mt-1">Browse latest news and articles across all categories.</p>
            </div>
            
            <form asp-action="Search" method="get" class="search-wrapper-lecturer">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="searchTerm" class="form-control-modern"
                       placeholder="Search articles..."
                       value="@ViewBag.SearchTerm" />
            </form>
        </div>

        <!-- Filter Badge -->
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="mb-2">
                <a asp-action="Index" class="badge-filter">
                    <i class="bi bi-search"></i>
                    Results for: "@ViewBag.SearchTerm"
                    <span class="close-btn ms-2">&times;</span>
                </a>
            </div>
        }

        <div class="row g-4">
            <!-- Main News Feed -->
            <div class="col-lg-8">
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string) && !Model.Any())
                {
                    <div class="alert alert-info border-0 p-5 text-center bg-light text-muted" style="border-radius: 12px; font-weight: 600;">
                        <i class="bi bi-search display-4 mb-3 d-block text-primary"></i>
                        <h5 class="font-weight-bold text-dark mb-2">No results found</h5>
                        <p class="mb-0">Try a different keyword or <a asp-action="Index" class="text-primary font-weight-bold">browse all articles</a>.</p>
                    </div>
                }
                else if (!Model.Any())
                {
                    <div class="alert alert-info border-0 p-5 text-center bg-light text-muted" style="border-radius: 12px; font-weight: 600;">
                        <i class="bi bi-newspaper display-4 mb-3 d-block text-primary"></i>
                        <h5 class="font-weight-bold text-dark mb-2">No articles yet</h5>
                        <p class="mb-0">Check back later for new content.</p>
                    </div>
                }
                else
                {
                    @if (ViewBag.Category != null)
                    {
                        <div class="mb-4">
                            <span class="badge-modern badge-modern-primary py-2 px-3 fs-6">
                                <i class="bi bi-tag-fill me-2"></i>Category: <strong>@ViewBag.Category.CategoryName</strong>
                            </span>
                        </div>
                    }

                    @foreach (var news in Model)
                    {
                        <a asp-action="Details" asp-route-id="@news.NewsArticleID" class="news-card-lecturer">
                            <div>
                                @{
                                    var cat = categories.FirstOrDefault(c => c.CategoryID == news.CategoryID);
                                    @if (cat != null)
                                    {
                                        <span class="card-category">
                                            <i class="bi bi-folder-fill me-1"></i>@cat.CategoryName
                                        </span>
                                    }
                                }
                                <div class="card-title">@news.NewsTitle</div>
                                @if (!string.IsNullOrEmpty(news.Headline))
                                {
                                    <div class="card-headline">@news.Headline</div>
                                }
                                <div class="card-meta">
                                    <span><i class="bi bi-calendar3-event-fill me-2"></i>@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                                    @if (!string.IsNullOrEmpty(news.NewsSource))
                                    {
                                        <span><i class="bi bi-link-45deg me-1"></i>@news.NewsSource</span>
                                    }
                                    <span class="read-more">Read Full Article <i class="bi bi-arrow-right"></i></span>
                                </div>
                            </div>
                        </a>
                    }
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Categories Card -->
                <div class="sidebar-card">
                    <div class="sidebar-card-header">
                        <i class="bi bi-folder-fill text-primary"></i>Categories
                    </div>
                    <div class="category-list">
                        <a asp-action="Index" class="category-item @(ViewBag.Category == null ? "active" : "")">
                            <span class="cat-dot"></span>
                            All Articles
                        </a>
                        @foreach (var category in categories)
                        {
                            <a asp-action="Category" asp-route-id="@category.CategoryID"
                               class="category-item @(ViewBag.Category?.CategoryID == category.CategoryID ? "active" : "")">
                                <span class="cat-dot"></span>
                                @category.CategoryName
                            </a>
                        }
                    </div>
                </div>

                <!-- Stats Card -->
                <div class="sidebar-card">
                    <div class="sidebar-card-header">
                        <i class="bi bi-bar-chart-fill text-primary"></i>Quick Stats
                    </div>
                    <div class="p-0">
                        <div class="quick-stats-item">
                            <span>Total Articles</span>
                            <strong>@Model.Count()</strong>
                        </div>
                        <div class="quick-stats-item">
                            <span>Active Categories</span>
                            <strong>@categories.Count()</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
