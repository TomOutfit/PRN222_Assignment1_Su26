@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = Model.NewsTitle;
}

<style>
    .article-header {
        background: var(--theme-public-gradient);
        color: white;
        padding: 50px 0;
        margin-bottom: 35px;
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px var(--theme-public-glow);
    }

    .article-header::before {
        content: '';
        position: absolute;
        top: -30%;
        left: -5%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }

    .article-header h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        line-height: 1.3;
        margin-top: 15px;
        position: relative;
        z-index: 1;
    }

    .article-meta {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: 20px;
        font-size: 14px;
        font-weight: 600;
        opacity: 0.95;
        flex-wrap: wrap;
    }

    .article-meta i {
        color: rgba(255, 255, 255, 0.8);
    }

    .article-body-card {
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        padding: 40px;
        margin-bottom: 25px;
    }

    .article-headline {
        font-size: 1.25rem;
        font-weight: 700;
        color: #334155;
        line-height: 1.6;
        margin-bottom: 30px;
        padding-bottom: 25px;
        border-bottom: 2px solid var(--border-color);
    }

    .article-content {
        font-size: 1.05rem;
        line-height: 1.95;
        color: #0f172a;
        font-weight: 400;
    }

    .article-content p {
        margin-bottom: 20px;
    }

    .article-source-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: #f8fafc;
        border: 1.5px solid var(--border-color);
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        color: #475569;
        margin-top: 30px;
    }

    .breadcrumb-custom {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        font-weight: 600;
        position: relative;
        z-index: 1;
    }

    .breadcrumb-custom a {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        transition: var(--transition-base);
    }

    .breadcrumb-custom a:hover {
        color: white;
    }

    .breadcrumb-custom .separator {
        color: rgba(255, 255, 255, 0.5);
    }

    .breadcrumb-custom .current {
        color: white;
        opacity: 0.85;
    }

    .btn-lecturer-secondary {
        background: #ffffff;
        color: #475569;
        border: 2.5px solid #e2e8f0;
        font-weight: 700;
        padding: 10px 22px;
        border-radius: 12px;
        transition: var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-lecturer-secondary:hover {
        border-color: #4f46e5;
        color: #4f46e5;
        transform: translateX(-3px);
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.1);
    }
</style>

<!-- Article Header -->
<div class="article-header">
    <div class="container-fluid px-4">
        <!-- Breadcrumb -->
        <div class="breadcrumb-custom">
            <a asp-action="Index"><i class="bi bi-house-door-fill"></i> Home</a>
            <span class="separator">/</span>
            <a asp-action="Index">Articles</a>
            <span class="separator">/</span>
            <span class="current">@(Model.NewsTitle?.Length > 35 ? Model.NewsTitle.Substring(0, 35) + "..." : Model.NewsTitle)</span>
        </div>

        <h1>@Model.NewsTitle</h1>

        <div class="article-meta">
            <span><i class="bi bi-calendar3-event-fill me-2"></i>@(Model.CreatedDate?.ToString("MMMM dd, yyyy") ?? "N/A")</span>
            <span><i class="bi bi-clock-fill me-2"></i>@(Model.CreatedDate?.ToString("HH:mm") ?? "")</span>
            @if (Model.CategoryID.HasValue)
            {
                <span><i class="bi bi-folder-fill me-2"></i>Category ID: @Model.CategoryID</span>
            }
        </div>
    </div>
</div>

<div class="container-fluid px-1">
    <div class="row">
        <div class="col-lg-9">
            <!-- Article Body -->
            <div class="article-body-card">
                @if (!string.IsNullOrEmpty(Model.Headline))
                {
                    <div class="article-headline">@Model.Headline</div>
                }

                <div class="article-content">
                    @Html.Raw((Model.NewsContent ?? "").Replace("\n", "<br/>"))
                </div>

                @if (!string.IsNullOrEmpty(Model.NewsSource))
                {
                    <div class="article-source-badge">
                        <i class="bi bi-link-45deg text-primary" style="font-size: 16px;"></i>
                        Source: <strong>@Model.NewsSource</strong>
                    </div>
                }

                @if (Model.ModifiedDate.HasValue)
                {
                    <div class="mt-4 text-muted font-weight-semibold" style="font-size: 13px;">
                        <i class="bi bi-pencil-fill me-1"></i>
                        Last updated: @(Model.ModifiedDate?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")
                    </div>
                }
            </div>

            <!-- Back Button -->
            <div class="mt-4">
                <a asp-action="Index" class="btn-lecturer-secondary">
                    <i class="bi bi-arrow-left"></i>Back to Articles
                </a>
            </div>
        </div>
    </div>
</div>
