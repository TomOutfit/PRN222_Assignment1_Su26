@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = Model.NewsTitle;
}

<style>
    .article-header {
        background: linear-gradient(135deg, #4a00e0 0%, #8e2de2 100%);
        color: white;
        padding: 50px 0;
        margin-bottom: 40px;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }

    .article-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }

    .article-header h1 {
        font-weight: 700;
        position: relative;
        z-index: 1;
        font-size: 1.8rem;
        line-height: 1.3;
    }

    .article-meta {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: 16px;
        font-size: 0.85rem;
        opacity: 0.85;
        flex-wrap: wrap;
    }

    .article-meta i {
        margin-right: 4px;
    }

    .article-body {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 40px;
    }

    .article-headline {
        font-size: 1.2rem;
        font-weight: 500;
        color: #555;
        line-height: 1.6;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid #f0f0f0;
    }

    .article-content {
        font-size: 1rem;
        line-height: 1.9;
        color: #333;
    }

    .article-content p {
        margin-bottom: 16px;
    }

    .article-source {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: #f8f9fa;
        border-radius: 10px;
        font-size: 0.85rem;
        color: #666;
        margin-top: 28px;
    }

    .breadcrumb-custom {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        margin-bottom: 16px;
    }

    .breadcrumb-custom a {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
    }

    .breadcrumb-custom a:hover {
        color: white;
    }

    .breadcrumb-custom .separator {
        opacity: 0.5;
    }

    .breadcrumb-custom .current {
        opacity: 0.7;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 12px;
        border: 2px solid rgba(255, 255, 255, 0.4);
        color: white;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        font-size: 0.9rem;
    }

    .btn-back:hover {
        background: rgba(255, 255, 255, 0.2);
        border-color: rgba(255, 255, 255, 0.6);
        color: white;
        transform: translateX(-2px);
    }
</style>

<!-- Article Header -->
<div class="article-header">
    <div class="container">
        <!-- Breadcrumb -->
        <div class="breadcrumb-custom">
            <a asp-action="Index"><i class="bi bi-house"></i> Home</a>
            <span class="separator">/</span>
            <a asp-action="Index">News</a>
            <span class="separator">/</span>
            <span class="current">@(Model.NewsTitle?.Length > 40 ? Model.NewsTitle.Substring(0, 40) + "..." : Model.NewsTitle)</span>
        </div>

        <h1>@Model.NewsTitle</h1>

        <div class="article-meta">
            <span><i class="bi bi-calendar3"></i>@(Model.CreatedDate?.ToString("MMMM dd, yyyy") ?? "N/A")</span>
            <span><i class="bi bi-clock"></i>@(Model.CreatedDate?.ToString("HH:mm") ?? "")</span>
            @if (Model.CategoryID.HasValue)
            {
                <span><i class="bi bi-folder"></i>Category @Model.CategoryID</span>
            }
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-lg-9">
            <!-- Article Body -->
            <div class="article-body">
                @if (!string.IsNullOrEmpty(Model.Headline))
                {
                    <div class="article-headline">@Model.Headline</div>
                }

                <div class="article-content">
                    @Html.Raw((Model.NewsContent ?? "").Replace("\n", "<br/>"))
                </div>

                @if (!string.IsNullOrEmpty(Model.NewsSource))
                {
                    <div class="article-source">
                        <i class="bi bi-link-45deg"></i>
                        Source: @Model.NewsSource
                    </div>
                }

                @if (Model.ModifiedDate.HasValue)
                {
                    <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                        <i class="bi bi-pencil me-1"></i>
                        Last updated: @(Model.ModifiedDate?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")
                    </div>
                }
            </div>

            <!-- Back Button -->
            <div class="mt-4">
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left"></i>Back to Articles
                </a>
            </div>
        </div>
    </div>
</div>
