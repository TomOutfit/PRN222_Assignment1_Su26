@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "My News History";
    var categoriesDict = ViewBag.CategoriesDict as Dictionary<short, string> ?? new Dictionary<short, string>();
}

<style>
    .staff-title-section {
        margin-bottom: 30px;
    }
    
    .staff-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .btn-staff-primary {
        background: var(--theme-staff-gradient);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px var(--theme-staff-glow);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-staff-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px var(--theme-staff-glow);
        color: white;
    }

    .btn-staff-secondary {
        background: #ffffff;
        color: #475569;
        border: 2.5px solid #e2e8f0;
        font-weight: 700;
        padding: 10px 22px;
        border-radius: 12px;
        transition: var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-staff-secondary:hover {
        border-color: #10b981;
        color: #10b981;
        transform: translateX(-3px);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1);
    }

    .btn-action-edit {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #e2e8f0;
        color: #475569;
        background: white;
        transition: var(--transition-base);
        text-decoration: none;
    }

    .btn-action-edit:hover {
        background: var(--theme-staff-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px var(--theme-staff-glow);
    }

    .btn-action-delete {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #fee2e2;
        color: #ef4444;
        background: white;
        transition: var(--transition-base);
        text-decoration: none;
    }

    .btn-action-delete:hover {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .stats-summary-card {
        background: #f8fafc;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 25px;
    }

    .stats-summary-item {
        font-size: 14.5px;
        font-weight: 600;
        color: #475569;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .stats-summary-item strong {
        color: #0f172a;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
    }

    .pagination-info strong {
        color: #10b981;
    }

    .table-modern td a {
        color: inherit;
        text-decoration: none;
        transition: var(--transition-base);
    }

    .table-modern td a:hover {
        color: #10b981;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="staff-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h1><i class="bi bi-clock-history me-3 text-success"></i>My News History</h1>
            <a asp-action="News" class="btn-staff-secondary">
                <i class="bi bi-arrow-left"></i>Manage News
            </a>
        </div>

        <div class="stats-summary-card d-flex align-items-center gap-4 flex-wrap">
            <span class="stats-summary-item"><i class="bi bi-collection-play-fill text-success"></i>Total Articles: <strong>@ViewBag.TotalItems</strong></span>
            <span class="stats-summary-item"><i class="bi bi-check-circle-fill text-success"></i>Active: <strong>@Model.Count(n => n.NewsStatus == true)</strong></span>
            <span class="stats-summary-item"><i class="bi bi-x-circle-fill text-muted"></i>Inactive: <strong>@Model.Count(n => n.NewsStatus != true)</strong></span>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info border-0 p-4 text-center bg-light text-muted" style="border-radius: 12px; font-weight: 600;">
                <i class="bi bi-journal-x display-4 mb-3 d-block"></i>You haven't created any news articles yet.
                <div class="mt-3">
                    <a asp-action="News" class="btn-staff-primary"><i class="bi bi-plus-lg me-2"></i>Create your first article</a>
                </div>
            </div>
        }
        else
        {
            <div class="card-modern">
                <div class="card-body p-4">
                    <div class="table-modern-wrapper">
                        <table class="table-modern w-100">
                            <thead>
                                <tr>
                                    <th style="width: 40%">Title</th>
                                    <th style="width: 15%">Category</th>
                                    <th style="width: 10%">Status</th>
                                    <th style="width: 15%">Created Date</th>
                                    <th style="width: 15%">Last Modified</th>
                                    <th style="width: 5%">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var news in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex flex-column" style="max-width: 350px;">
                                                <strong class="text-dark font-weight-bold" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    <a asp-controller="Home" asp-action="Details" asp-route-id="@news.NewsArticleID" target="_blank">
                                                        @news.NewsTitle
                                                    </a>
                                                </strong>
                                                @if (!string.IsNullOrEmpty(news.Headline))
                                                {
                                                    <span class="text-muted small mt-1" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@news.Headline</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (news.CategoryID.HasValue && categoriesDict.ContainsKey(news.CategoryID.Value))
                                            {
                                                <span class="badge-modern badge-modern-secondary">@categoriesDict[news.CategoryID.Value]</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            @if (news.NewsStatus == true)
                                            {
                                                <span class="badge-modern badge-modern-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge-modern badge-modern-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td style="color: #64748b; font-weight: 500;">@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                        <td style="color: #64748b; font-weight: 500;">
                                            @if (news.ModifiedDate.HasValue)
                                            {
                                                @news.ModifiedDate.Value.ToString("MMM dd, yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-action="News" asp-route-searchTerm="@news.NewsTitle" class="btn-action-edit">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
                    {
                        var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                        var totalPages = (int)(ViewBag.TotalPages ?? 1);
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage = Math.Min(totalPages, currentPage + 2);

                        <div class="pagination-wrapper">
                            <div class="pagination-info">
                                Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                                to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                                of <strong>@ViewBag.TotalItems</strong> articles
                            </div>
                            <nav aria-label="News History pagination">
                                <ul class="pagination pagination-modern mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" asp-action="NewsHistory" asp-route-page="1" title="First">
                                            <i class="bi bi-chevron-double-left"></i>
                                        </a>
                                    </li>
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" asp-action="NewsHistory" asp-route-page="@(currentPage - 1)" title="Previous">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" asp-action="NewsHistory" asp-route-page="@i">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" asp-action="NewsHistory" asp-route-page="@(currentPage + 1)" title="Next">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" asp-action="NewsHistory" asp-route-page="@totalPages" title="Last">
                                            <i class="bi bi-chevron-double-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
