@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "My News History";
    var categoriesDict = ViewBag.CategoriesDict as Dictionary<short, string> ?? new Dictionary<short, string>();
}

<style>
    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
        flex-wrap: wrap;
        gap: 10px;
    }
    .pagination-info {
        font-size: 14px;
        color: #888;
    }
    .pagination-info strong {
        color: #667eea;
    }
    .pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
        border: none;
        color: #555;
        font-weight: 500;
        padding: 8px 14px;
        transition: all 0.2s;
    }
    .pagination .page-link:hover {
        background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1));
        color: #667eea;
    }
    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(102,126,234,0.3);
    }
    .pagination .page-item.disabled .page-link {
        color: #ccc;
        background: transparent;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>My News History</h1>
    <a asp-action="News" class="btn btn-primary">Manage News</a>
</div>

<div class="alert alert-info">
    <strong>Total:</strong> @ViewBag.TotalItems |
    <strong>Active:</strong> @Model.Count(n => n.NewsStatus == true) |
    <strong>Inactive:</strong> @Model.Count(n => n.NewsStatus != true)
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        You haven't created any news articles yet.
        <a asp-action="CreateNews" class="btn btn-sm btn-primary ms-2">Create your first article</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th>Last Modified</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var news in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@news.NewsTitle</strong>
                                    @if (!string.IsNullOrEmpty(news.Headline))
                                    {
                                        <br /><small class="text-muted">@news.Headline</small>
                                    }
                                </td>
                                <td>
                                    @if (news.CategoryID.HasValue && categoriesDict.ContainsKey(news.CategoryID.Value))
                                    {
                                        @categoriesDict[news.CategoryID.Value]
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (news.NewsStatus == true)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>
                                    @if (news.ModifiedDate.HasValue)
                                    {
                                        @news.ModifiedDate.Value.ToString("MMM dd, yyyy")
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditNews" asp-route-id="@news.NewsArticleID"
                                       class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="DeleteNews" asp-route-id="@news.NewsArticleID"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                var totalPages = (int)(ViewBag.TotalPages ?? 1);
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);

                <div class="pagination-wrapper">
                    <div class="pagination-info">
                        Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                        to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                        of <strong>@ViewBag.TotalItems</strong> articles
                    </div>
                    <nav aria-label="News History pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="NewsHistory" asp-route-page="1" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="NewsHistory" asp-route-page="@(currentPage - 1)" title="Previous">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="NewsHistory" asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="NewsHistory" asp-route-page="@(currentPage + 1)" title="Next">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="NewsHistory" asp-route-page="@totalPages" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
}
