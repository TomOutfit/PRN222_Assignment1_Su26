@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = "Create News Article";
}

<div class="row">
    <div class="col-md-8">
        <h1>Create News Article</h1>
        
        <form asp-action="CreateNews" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="NewsTitle" class="form-label"></label>
                <input asp-for="NewsTitle" class="form-control" />
                <span asp-validation-for="NewsTitle" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Headline" class="form-label"></label>
                <input asp-for="Headline" class="form-control" />
                <span asp-validation-for="Headline" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="NewsSource" class="form-label"></label>
                <input asp-for="NewsSource" class="form-control" />
                <span asp-validation-for="NewsSource" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="CategoryID" class="form-label">Category</label>
                <select asp-for="CategoryID" class="form-control" asp-items="@(new SelectList(ViewBag.Categories, "CategoryID", "CategoryName"))">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryID" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="NewsContent" class="form-label"></label>
                <textarea asp-for="NewsContent" class="form-control" rows="10"></textarea>
                <span asp-validation-for="NewsContent" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label class="form-label">Tags</label>
                <div class="row">
                    @if (ViewBag.Tags != null)
                    {
                        @foreach (var tag in ViewBag.Tags)
                        {
                            <div class="col-md-4 mb-2">
                                <div class="form-check">
                                    <input type="checkbox" name="selectedTags" value="@tag.TagID" class="form-check-input" id="tag_@tag.TagID" />
                                    <label class="form-check-label" for="tag_@tag.TagID">@tag.TagName</label>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            
            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="NewsStatus" class="form-check-input" checked />
                    <label asp-for="NewsStatus" class="form-check-label">Active</label>
                </div>
                <span asp-validation-for="NewsStatus" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="News" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
