@{
    ViewData["Title"] = "Staff Dashboard";
}

<style>
    .dashboard-header {
        background: var(--theme-staff-gradient);
        color: white;
        padding: 50px 0;
        margin-bottom: 35px;
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px var(--theme-staff-glow);
    }

    .dashboard-header::before {
        content: '';
        position: absolute;
        top: -30%;
        left: -5%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }

    .dashboard-header h1 {
        font-weight: 800;
        font-size: 2.6rem;
        letter-spacing: -0.5px;
    }

    .dashboard-header p {
        opacity: 0.9;
        font-weight: 500;
    }

    .stat-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 24px 28px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        display: flex;
        align-items: center;
        gap: 20px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        transition: var(--transition-base);
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 35px rgba(16, 185, 129, 0.05);
        border-color: rgba(16, 185, 129, 0.15);
    }

    .stat-card .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .stat-card .stat-body {
        min-width: 0;
    }

    .stat-card .stat-number {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
        letter-spacing: -0.5px;
    }

    .stat-card .stat-label {
        color: #64748b;
        font-size: 0.88rem;
        font-weight: 600;
        margin-top: 2px;
    }

    .section-label {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 16px;
        padding-left: 4px;
    }

    .chart-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(226, 232, 240, 0.8);
    }

    .chart-card .chart-title {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 25px;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: -0.25px;
    }
</style>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-person-badge me-3"></i>Staff Dashboard</h1>
                <p class="mb-0">Manage your news content and categories.</p>
            </div>
            <div class="col-md-4 text-md-end text-center mt-3 mt-md-0">
                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="section-label">Your Statistics</div>
<div class="row g-4 mb-5">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #4f46e5, #6366f1); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);">
                <i class="bi bi-folder"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="categoryCount">@ViewBag.CategoryCount</div>
                <div class="stat-label">Categories</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #0284c7, #0ea5e9); box-shadow: 0 4px 12px rgba(2, 132, 199, 0.2);">
                <i class="bi bi-newspaper"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="newsCount">@ViewBag.NewsCount</div>
                <div class="stat-label">News Articles</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: var(--theme-staff-gradient); box-shadow: 0 4px 12px var(--theme-staff-glow);">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="activeNewsCount">@ViewBag.ActiveNewsCount</div>
                <div class="stat-label">Active Articles</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #d97706, #f59e0b); box-shadow: 0 4px 12px rgba(217, 119, 6, 0.2);">
                <i class="bi bi-clock-history"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="userNewsCount">@ViewBag.UserNewsCount</div>
                <div class="stat-label">Your Articles</div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="section-label">Analytics</div>
<div class="row g-4">
    <div class="col-lg-6">
        <div class="chart-card">
            <div class="chart-title">
                <i class="bi bi-pie-chart" style="color: #059669; font-size: 1.2rem;"></i>
                News by Category
            </div>
            <canvas id="newsByCategoryChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="chart-card">
            <div class="chart-title">
                <i class="bi bi-bar-chart" style="color: #059669; font-size: 1.2rem;"></i>
                Active vs Inactive Articles
            </div>
            <canvas id="activeVsInactiveChart" height="200"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let newsByCategoryChart, activeVsInactiveChart;

        const categoryColors = [
            '#10b981', '#34d399', '#6ee7b7', '#a7f3d0',
            '#059669', '#047857', '#065f46', '#064e3b',
            '#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe'
        ];

        async function fetchChartData() {
            try {
                const response = await fetch('/Staff/GetChartData');
                if (!response.ok) return;
                const data = await response.json();

                const catLabels = Object.keys(data.newsByCategory);
                const catValues = Object.values(data.newsByCategory);

                if (newsByCategoryChart) {
                    newsByCategoryChart.data.labels = catLabels;
                    newsByCategoryChart.data.datasets[0].data = catValues;
                    newsByCategoryChart.update();
                } else {
                    const ctx = document.getElementById('newsByCategoryChart').getContext('2d');
                    newsByCategoryChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: catLabels,
                            datasets: [{
                                data: catValues,
                                backgroundColor: categoryColors.slice(0, catLabels.length),
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            cutout: '68%',
                            plugins: { 
                                legend: { 
                                    position: 'bottom', 
                                    labels: { 
                                        padding: 20, 
                                        usePointStyle: true, 
                                        font: { size: 12, weight: 'bold' } 
                                    } 
                                } 
                            }
                        }
                    });
                }

                const statusLabels = Object.keys(data.activeVsInactive);
                const statusValues = Object.values(data.activeVsInactive);

                if (activeVsInactiveChart) {
                    activeVsInactiveChart.data.labels = statusLabels;
                    activeVsInactiveChart.data.datasets[0].data = statusValues;
                    activeVsInactiveChart.update();
                } else {
                    const ctx2 = document.getElementById('activeVsInactiveChart').getContext('2d');
                    activeVsInactiveChart = new Chart(ctx2, {
                        type: 'doughnut',
                        data: {
                            labels: statusLabels,
                            datasets: [{
                                data: statusValues,
                                backgroundColor: ['#10b981', '#64748b'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            cutout: '68%',
                            plugins: { 
                                legend: { 
                                    position: 'bottom', 
                                    labels: { 
                                        padding: 20, 
                                        usePointStyle: true, 
                                        font: { size: 12, weight: 'bold' } 
                                    } 
                                } 
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Failed to fetch chart data:', e);
            }
        }

        async function fetchStats() {
            try {
                const response = await fetch('/Staff/GetStats');
                if (!response.ok) return;
                const data = await response.json();

                const statMap = {
                    categoryCount: data.categoryCount,
                    newsCount: data.newsCount,
                    activeNewsCount: data.activeNewsCount,
                    userNewsCount: data.userNewsCount
                };

                for (const [key, value] of Object.entries(statMap)) {
                    const el = document.querySelector(`[data-stat="${key}"]`);
                    if (el && el.textContent.trim() !== String(value)) {
                        el.textContent = value;
                        el.style.animation = 'none';
                        el.offsetHeight;
                        el.style.animation = 'popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1)';
                    }
                }
            } catch (e) {
                console.error('Failed to fetch stats:', e);
            }
        }

        fetchChartData();
        fetchStats();
        setInterval(fetchChartData, 10000);
        setInterval(fetchStats, 5000);
    </script>
    <style>
        @@keyframes popIn {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); color: #10b981; }
            100% { transform: scale(1); }
        }
    </style>
}
