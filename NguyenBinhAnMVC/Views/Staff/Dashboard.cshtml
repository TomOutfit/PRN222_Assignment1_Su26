@{
    ViewData["Title"] = "Staff Dashboard";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 40px 0;
        margin-bottom: 40px;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }
    
    .dashboard-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }
    
    .dashboard-header h1 {
        font-weight: 700;
        position: relative;
        z-index: 1;
    }
    
    .dashboard-header p {
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }
    
    .dashboard-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        transition: all 0.4s ease;
        overflow: hidden;
        height: 100%;
        position: relative;
    }
    
    .dashboard-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #11998e, #38ef7d);
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }
    
    .dashboard-card:hover::before {
        transform: scaleX(1);
    }
    
    .dashboard-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }
    
    .dashboard-card .card-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 30px;
        color: white;
    }
    
    .dashboard-card .card-title {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 8px;
    }
    
    .dashboard-card .card-text {
        color: #666;
        font-size: 0.9rem;
    }
    
    .dashboard-card .btn {
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 500;
        transition: all 0.3s;
    }
    
    .icon-categories { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .icon-news { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .icon-profile { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .icon-history { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    
    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }
    
    .stat-card .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }
    
    .stat-card .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    
    .stat-card .stat-label {
        color: #888;
        font-size: 0.9rem;
    }
</style>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-person-badge me-3"></i>Staff Dashboard</h1>
                <p class="mb-0">Welcome back! Manage your news content and categories from here.</p>
            </div>
            <div class="col-md-4 text-md-end text-center mt-3 mt-md-0">
                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <i class="bi bi-folder"></i>
                </div>
                <div>
                    <div class="stat-number">@ViewBag.CategoryCount</div>
                    <div class="stat-label">Categories</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <i class="bi bi-newspaper"></i>
                </div>
                <div>
                    <div class="stat-number">@ViewBag.NewsCount</div>
                    <div class="stat-label">News Articles</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="stat-number">@ViewBag.ActiveNewsCount</div>
                    <div class="stat-label">Active Articles</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div>
                    <div class="stat-number">@ViewBag.UserNewsCount</div>
                    <div class="stat-label">Your Articles</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Dashboard Cards -->
<div class="row g-4">
    <div class="col-md-3">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-categories">
                    <i class="bi bi-folder"></i>
                </div>
                <h5 class="card-title">Categories</h5>
                <p class="card-text">Create and manage news categories for your content</p>
                <a asp-action="Categories" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>Manage
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-news">
                    <i class="bi bi-newspaper"></i>
                </div>
                <h5 class="card-title">News Articles</h5>
                <p class="card-text">Create, edit and manage your news articles</p>
                <a asp-action="News" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>Manage
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-profile">
                    <i class="bi bi-person-circle"></i>
                </div>
                <h5 class="card-title">Profile</h5>
                <p class="card-text">Update your profile information and settings</p>
                <a asp-action="Profile" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>Manage
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-history">
                    <i class="bi bi-clock-history"></i>
                </div>
                <h5 class="card-title">News History</h5>
                <p class="card-text">View and track your published news articles</p>
                <a asp-action="NewsHistory" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>View
                </a>
            </div>
        </div>
    </div>
</div>
