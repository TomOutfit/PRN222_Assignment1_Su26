@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = "Delete News Article";
}

<div class="row">
    <div class="col-md-8">
        <h1>Delete News Article</h1>
        
        <div class="alert alert-warning">
            <h3>Are you sure you want to delete this news article?</h3>
            <p>This action cannot be undone.</p>
        </div>
        
        <div class="card">
            <div class="card-body">
                <h4>@Model.NewsTitle</h4>
                
                @if (!string.IsNullOrEmpty(Model.Headline))
                {
                    <p class="text-muted">@Model.Headline</p>
                }
                
                <dl class="row">
                    <dt class="col-sm-2">Category ID:</dt>
                    <dd class="col-sm-10">@Model.CategoryID</dd>
                    
                    <dt class="col-sm-2">Status:</dt>
                    <dd class="col-sm-10">
                        @if (Model.NewsStatus == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-2">Created By ID:</dt>
                    <dd class="col-sm-10">@Model.CreatedByID</dd>
                    
                    <dt class="col-sm-2">Created Date:</dt>
                    <dd class="col-sm-10">@(Model.CreatedDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")</dd>
                </dl>
                
                @if (!string.IsNullOrEmpty(Model.NewsContent))
                {
                    <div class="mt-3">
                        <h6>Content Preview:</h6>
                        <p class="text-muted">@(Model.NewsContent.Length > 200 ? Model.NewsContent.Substring(0, 200) + "..." : Model.NewsContent)</p>
                    </div>
                }
                
                <form asp-action="DeleteNewsConfirmed" method="post" class="mt-3">
                    <input type="hidden" asp-for="NewsArticleID" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="News" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
