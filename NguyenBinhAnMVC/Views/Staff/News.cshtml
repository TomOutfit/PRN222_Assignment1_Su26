@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "Manage News";
    var categoriesDict = ViewBag.CategoriesDict as Dictionary<short, string> ?? new Dictionary<short, string>();
    var categories = ViewBag.Categories as IEnumerable<NguyenBinhAn_A01_Data.Models.Category>
                     ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Category>();
    var tags = ViewBag.Tags as IEnumerable<NguyenBinhAn_A01_Data.Models.Tag>
               ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Tag>();
}

<style>
    .staff-title-section {
        margin-bottom: 30px;
    }
    
    .staff-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .btn-staff-primary {
        background: var(--theme-staff-gradient);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px var(--theme-staff-glow);
    }

    .btn-staff-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px var(--theme-staff-glow);
        color: white;
    }

    .btn-staff-danger {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px rgba(220, 38, 38, 0.2);
    }

    .btn-staff-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.3);
        color: white;
    }

    .btn-action-edit {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #e2e8f0;
        color: #475569;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-edit:hover {
        background: var(--theme-staff-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px var(--theme-staff-glow);
    }

    .btn-action-delete {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #fee2e2;
        color: #ef4444;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-delete:hover {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .search-wrapper .form-control-modern {
        border-radius: 12px 0 0 12px !important;
        border-right: none;
    }

    .search-wrapper .btn-search {
        border-radius: 0 12px 12px 0;
        border: 2.5px solid var(--border-color);
        background: #f8fafc;
        color: #475569;
        font-weight: 700;
        padding: 0 20px;
        transition: var(--transition-base);
    }

    .search-wrapper .btn-search:hover {
        background: #f1f5f9;
        color: #0f172a;
    }

    .search-wrapper .btn-clear {
        border-radius: 12px;
        margin-left: 10px;
        font-weight: 700;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
    }

    .pagination-info strong {
        color: #10b981;
    }

    .modal-modern .modal-content {
        border: none;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    }

    .modal-modern .modal-header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .modal-header .modal-title {
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.25px;
    }

    .modal-modern .modal-body {
        padding: 2rem;
    }

    .modal-modern .modal-footer {
        border-top: 1px solid var(--border-color);
        padding: 1.25rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .form-label {
        font-weight: 700;
        color: #334155;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .tags-container {
        border: 2px solid var(--border-color);
        border-radius: 12px;
        padding: 15px;
        max-height: 200px;
        overflow-y: auto;
        background: #ffffff;
    }

    .tags-container::-webkit-scrollbar {
        width: 6px;
    }

    .tags-container::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

    .tag-checkbox-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .tag-checkbox-item:last-child {
        margin-bottom: 0;
    }

    .tag-checkbox-item label {
        font-size: 14px;
        font-weight: 500;
        color: #334155;
    }
</style>

<div class="staff-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
    <h1><i class="bi bi-newspaper me-3 text-success"></i>Manage News</h1>
    <button type="button" class="btn-staff-primary" data-bs-toggle="modal" data-bs-target="#createNewsModal">
        <i class="bi bi-plus-lg me-2"></i>Create New Article
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #dcfce7; color: #15803d; font-weight: 600;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #fee2e2; color: #b91c1c; font-weight: 600;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-modern">
    <div class="card-body p-4">
        <!-- Search Form -->
        <form asp-action="News" method="get" class="mb-4">
            <div class="input-group search-wrapper">
                <input type="text" name="searchTerm" class="form-control-modern w-auto flex-grow-1"
                       placeholder="Search by title or headline..."
                       value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn-search"><i class="bi bi-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <a asp-action="News" class="btn btn-outline-secondary btn-clear px-4 py-2 d-flex align-items-center">
                        <i class="bi bi-x-circle me-2"></i>Clear
                    </a>
                }
            </div>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="alert alert-light border shadow-none mb-3 d-inline-block px-3 py-2" style="border-radius: 8px; font-weight: 600; font-size: 14px; background: #f8fafc;">
                <i class="bi bi-search me-2 text-success"></i>Results for: "<strong>@ViewBag.SearchTerm</strong>" — <strong>@ViewBag.TotalItems</strong> found
            </div>
        }

        @if (!Model.Any())
        {
            <div class="alert alert-info border-0 p-4 text-center bg-light text-muted" style="border-radius: 12px; font-weight: 600;">
                <i class="bi bi-newspaper display-4 mb-3 d-block"></i>No news articles found.
            </div>
        }
        else
        {
            <div class="table-modern-wrapper">
                <table class="table-modern w-100">
                    <thead>
                        <tr>
                            <th style="width: 45%">Title</th>
                            <th style="width: 15%">Category</th>
                            <th style="width: 10%">Status</th>
                            <th style="width: 15%">Created Date</th>
                            <th style="width: 15%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var news in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column" style="max-width: 400px;">
                                        <strong class="text-dark font-weight-bold" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@news.NewsTitle</strong>
                                        @if (!string.IsNullOrEmpty(news.Headline))
                                        {
                                            <span class="text-muted small mt-1" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@news.Headline</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (news.CategoryID.HasValue && categoriesDict.ContainsKey(news.CategoryID.Value))
                                    {
                                        <span class="badge-modern badge-modern-secondary">@categoriesDict[news.CategoryID.Value]</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (news.NewsStatus == true)
                                    {
                                        <span class="badge-modern badge-modern-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-modern-secondary">Inactive</span>
                                    }
                                </td>
                                <td style="color: #64748b; font-weight: 500;">@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn-action-edit"
                                                onclick="loadEditNewsModal('@news.NewsArticleID')">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </button>
                                        <button type="button" class="btn-action-delete"
                                                onclick="openDeleteNewsModal('@news.NewsArticleID', '@Html.Raw((news.NewsTitle ?? "").Replace("'", "\\'"))')">
                                            <i class="bi bi-trash-fill me-1"></i>Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                var totalPages = (int)(ViewBag.TotalPages ?? 1);
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);

                <div class="pagination-wrapper">
                    <div class="pagination-info">
                        Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                        to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                        of <strong>@ViewBag.TotalItems</strong> articles
                    </div>
                    <nav aria-label="News pagination">
                        <ul class="pagination pagination-modern mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="1" asp-route-searchTerm="@ViewBag.SearchTerm" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Previous">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="News" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Next">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@totalPages" asp-route-searchTerm="@ViewBag.SearchTerm" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<!-- Create News Modal -->
<div class="modal modal-modern fade" id="createNewsModal" tabindex="-1" aria-labelledby="createNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="CreateNews" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createNewsModalLabel"><i class="bi bi-plus-circle text-success me-2"></i>Create News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-4">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" name="NewsTitle" class="form-control-modern w-100" required maxlength="400" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Headline <span class="text-danger">*</span></label>
                                <input type="text" name="Headline" class="form-control-modern w-100" required maxlength="150" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Content</label>
                                <textarea name="NewsContent" class="form-control-modern w-100" rows="8" maxlength="4000"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Source</label>
                                <input type="text" name="NewsSource" class="form-control-modern w-100" maxlength="400" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Category <span class="text-danger">*</span></label>
                                <select name="CategoryID" class="form-select-modern w-100" required>
                                    <option value="">-- Select Category --</option>
                                    @foreach (var c in categories)
                                    {
                                        <option value="@c.CategoryID">@c.CategoryName</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <div class="form-check d-flex align-items-center gap-2 mt-4 mb-3">
                                    <input type="checkbox" name="NewsStatus" value="true" class="form-check-input mt-0"
                                           id="createNewsStatus" checked />
                                    <label class="form-check-label font-weight-bold text-dark mb-0" for="createNewsStatus" style="font-size: 14.5px;">Active Status</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tags</label>
                                <div class="tags-container">
                                    @foreach (var tag in tags)
                                    {
                                        <div class="tag-checkbox-item">
                                            <input type="checkbox" name="selectedTags" value="@tag.TagID"
                                                   class="form-check-input" id="ctag_@tag.TagID" />
                                            <label class="form-check-label" for="ctag_@tag.TagID">@tag.TagName</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-primary">Create Article</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit News Modal -->
<div class="modal modal-modern fade" id="editNewsModal" tabindex="-1" aria-labelledby="editNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditNews" method="post" id="editNewsForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editNewsId" name="NewsArticleID" />
                <input type="hidden" id="editNewsCreatedById" name="CreatedByID" />
                <input type="hidden" id="editNewsCreatedDate" name="CreatedDate" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editNewsModalLabel"><i class="bi bi-pencil-square text-success me-2"></i>Edit News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editNewsModalBody">
                    <div class="text-center py-5">
                        <div class="spinner-border text-success" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Loading article data...</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal modal-modern fade" id="deleteNewsModal" tabindex="-1" aria-labelledby="deleteNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <form asp-action="DeleteNews" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteNewsId" name="id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteNewsModalLabel" style="color: white;"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-trash-fill text-danger display-4 mb-3 d-block"></i>
                    <h5 class="font-weight-bold text-dark mb-3">Are you sure you want to delete this article?</h5>
                    <div class="p-3 mb-3 border" style="border-radius: 12px; background-color: #f8fafc;">
                        <h6 class="font-weight-bold mb-0 text-dark" id="deleteNewsTitle"></h6>
                    </div>
                    <p class="text-danger font-weight-bold mb-0"><i class="bi bi-info-circle-fill me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-danger">Yes, Delete Article</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var categoriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        categories.Select(c => new { id = c.CategoryID, name = c.CategoryName })));
    var tagsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        tags.Select(t => new { id = t.TagID, name = t.TagName })));

    function loadEditNewsModal(newsId) {
        var modal = new bootstrap.Modal(document.getElementById('editNewsModal'));
        document.getElementById('editNewsModalBody').innerHTML =
            '<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div><p class="mt-2 text-muted">Loading article data...</p></div>';
        modal.show();

        fetch('/Staff/GetNewsJson?id=' + encodeURIComponent(newsId))
            .then(r => r.json())
            .then(data => {
                document.getElementById('editNewsId').value = data.newsArticleID;
                document.getElementById('editNewsCreatedById').value = data.createdByID ?? '';
                document.getElementById('editNewsCreatedDate').value = data.createdDate ?? '';
                renderEditBody(data);
            })
            .catch(() => {
                document.getElementById('editNewsModalBody').innerHTML =
                    '<div class="alert alert-danger border-0 p-3" style="border-radius: 8px;"><i class="bi bi-exclamation-circle me-2"></i>Failed to load article data. Please try again.</div>';
            });
    }

    function renderEditBody(data) {
        var catOptions = categoriesData.map(c =>
            `<option value="${c.id}" ${data.categoryID == c.id ? 'selected' : ''}>${c.name}</option>`
        ).join('');

        var tagChecks = tagsData.map(t =>
            `<div class="tag-checkbox-item">
                <input type="checkbox" name="selectedTags" value="${t.id}"
                       class="form-check-input" id="etag_${t.id}"
                       ${data.tagIds && data.tagIds.includes(t.id) ? 'checked' : ''} />
                <label class="form-check-label" for="etag_${t.id}">${t.name}</label>
             </div>`
        ).join('');

        document.getElementById('editNewsModalBody').innerHTML = `
            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" name="NewsTitle" class="form-control-modern w-100" required maxlength="400"
                               value="${escHtml(data.newsTitle ?? '')}" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Headline <span class="text-danger">*</span></label>
                        <input type="text" name="Headline" class="form-control-modern w-100" required maxlength="150"
                               value="${escHtml(data.headline ?? '')}" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="NewsContent" class="form-control-modern w-100" rows="8" maxlength="4000">${escHtml(data.newsContent ?? '')}</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source</label>
                        <input type="text" name="NewsSource" class="form-control-modern w-100" maxlength="400"
                               value="${escHtml(data.newsSource ?? '')}" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Category <span class="text-danger">*</span></label>
                        <select name="CategoryID" class="form-select-modern w-100" required>
                            <option value="">-- Select Category --</option>
                            ${catOptions}
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center gap-2 mt-4 mb-3">
                            <input type="checkbox" name="NewsStatus" value="true" class="form-check-input mt-0"
                                   id="editNewsStatus" ${data.newsStatus ? 'checked' : ''} />
                            <label class="form-check-label font-weight-bold text-dark mb-0" for="editNewsStatus" style="font-size: 14.5px;">Active Status</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <div class="tags-container">
                            ${tagChecks}
                        </div>
                    </div>
                </div>
            </div>`;
    }

    function openDeleteNewsModal(id, title) {
        document.getElementById('deleteNewsId').value = id;
        document.getElementById('deleteNewsTitle').textContent = title;
        new bootstrap.Modal(document.getElementById('deleteNewsModal')).show();
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
</script>
}
