@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "Manage News";
    var categoriesDict = ViewBag.CategoriesDict as Dictionary<short, string> ?? new Dictionary<short, string>();
    var categories = ViewBag.Categories as IEnumerable<NguyenBinhAn_A01_Data.Models.Category>
                     ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Category>();
    var tags = ViewBag.Tags as IEnumerable<NguyenBinhAn_A01_Data.Models.Tag>
               ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Tag>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 40px 0;
        margin-bottom: 40px;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }
    
    .page-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }
    
    .page-header h1 {
        font-weight: 700;
        position: relative;
        z-index: 1;
    }
    
    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
    }
    
    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        color: white;
    }
    
    .content-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .search-box .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #e8e8e8;
        transition: all 0.3s;
    }
    
    .search-box .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
    
    .table-modern {
        border-collapse: separate;
        border-spacing: 0;
    }
    
    .table-modern thead th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-weight: 600;
        border: none;
        padding: 15px 20px;
    }
    
    .table-modern thead th:first-child {
        border-radius: 12px 0 0 12px;
    }
    
    .table-modern thead th:last-child {
        border-radius: 0 12px 12px 0;
    }
    
    .table-modern tbody tr {
        transition: all 0.3s;
    }
    
    .table-modern tbody tr:hover {
        background: #f8f9fa;
    }
    
    .table-modern td {
        padding: 18px 20px;
        vertical-align: middle;
        border-color: #f0f0f0;
    }
    
    .table-modern .title-cell {
        max-width: 300px;
    }
    
    .table-modern .title-cell strong {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }
    
    .status-active {
        background: #d4edda;
        color: #155724;
    }
    
    .status-inactive {
        background: #e2e3e5;
        color: #383d41;
    }
    
    .action-btn {
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        transition: all 0.3s;
    }
    
    .action-btn:hover {
        transform: translateY(-1px);
    }
    
    .modal-modern .modal-content {
        border: none;
        border-radius: 20px;
        overflow: hidden;
    }
    
    .modal-modern .modal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 20px 25px;
    }
    
    .modal-modern .modal-header .btn-close {
        filter: brightness(0) invert(1);
    }
    
    .modal-modern .modal-body {
        padding: 25px;
    }
    
    .modal-modern .modal-footer {
        border-top: 1px solid #f0f0f0;
        padding: 20px 25px;
    }
    
    .form-control-modern {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #e8e8e8;
        transition: all 0.3s;
    }
    
    .form-control-modern:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
    
    .form-select-modern {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #e8e8e8;
        transition: all 0.3s;
    }
    
    .form-select-modern:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1><i class="bi bi-newspaper me-3"></i>Manage News</h1>
                <p class="mb-0 opacity-75">Create, edit and manage your news articles</p>
            </div>
            <div class="col-md-3">
                <button type="button" class="btn btn-create w-100" data-bs-toggle="modal" data-bs-target="#createNewsModal">
                    <i class="bi bi-plus-lg me-2"></i>Create New Article
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Alerts -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Content Card -->
<div class="content-card">
    <div class="card-body p-4">
        <!-- Search Form -->
        <form asp-action="News" method="get" class="mb-4">
            <div class="row g-3">
                <div class="col-md-10">
                    <div class="search-box">
                        <input type="text" name="searchTerm" class="form-control"
                               placeholder="Search by title or headline..."
                               value="@ViewBag.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
            {
                <div class="mt-3">
                    <a asp-action="News" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Clear Search
                    </a>
                </div>
            }
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="alert alert-light border mb-4">
                <i class="bi bi-search me-2"></i>Results for: "<strong>@ViewBag.SearchTerm</strong>" — <strong>@ViewBag.TotalItems</strong> found
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-newspaper" style="font-size: 60px; opacity: 0.3;"></i>
                <h4 class="mt-3 text-muted">No news articles found</h4>
                <p class="text-muted">Click "Create New Article" to get started.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-modern">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var news in Model)
                        {
                            <tr>
                                <td class="title-cell">
                                    <strong>@news.NewsTitle</strong>
                                    @if (!string.IsNullOrEmpty(news.Headline))
                                    {
                                        <small class="text-muted d-block" style="font-size: 12px;">@news.Headline</small>
                                    }
                                </td>
                                <td>
                                    @if (news.CategoryID.HasValue && categoriesDict.ContainsKey(news.CategoryID.Value))
                                    {
                                        <span class="text-muted">@categoriesDict[news.CategoryID.Value]</span>
                                    }
                                    else { <span class="text-muted">N/A</span> }
                                </td>
                                <td>
                                    @if (news.NewsStatus == true)
                                    { <span class="status-badge status-active"><i class="bi bi-check-circle me-1"></i>Active</span> }
                                    else
                                    { <span class="status-badge status-inactive"><i class="bi bi-clock me-1"></i>Inactive</span> }
                                </td>
                                <td>@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-primary action-btn"
                                            onclick="loadEditNewsModal('@news.NewsArticleID')">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger action-btn"
                                            onclick="openDeleteNewsModal('@news.NewsArticleID', '@Html.Raw((news.NewsTitle ?? "").Replace("'", "\\'"))')">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                var totalPages = (int)(ViewBag.TotalPages ?? 1);
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);

                <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                    <div class="pagination-info">
                        Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                        to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                        of <strong>@ViewBag.TotalItems</strong> articles
                    </div>
                    <nav aria-label="News pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="1" asp-route-searchTerm="@ViewBag.SearchTerm" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Previous">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="News" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Next">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="News" asp-route-page="@totalPages" asp-route-searchTerm="@ViewBag.SearchTerm" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<!-- Create News Modal -->
<div class="modal fade modal-modern" id="createNewsModal" tabindex="-1" aria-labelledby="createNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form asp-action="CreateNews" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createNewsModalLabel"><i class="bi bi-plus-circle me-2"></i>Create News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" name="NewsTitle" class="form-control form-control-modern" required maxlength="400" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Headline <span class="text-danger">*</span></label>
                                <input type="text" name="Headline" class="form-control form-control-modern" required maxlength="150" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Content</label>
                                <textarea name="NewsContent" class="form-control form-control-modern" rows="8" maxlength="4000"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Source</label>
                                <input type="text" name="NewsSource" class="form-control form-control-modern" maxlength="400" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Category <span class="text-danger">*</span></label>
                                <select name="CategoryID" class="form-select form-select-modern" required>
                                    <option value="">-- Select Category --</option>
                                    @foreach (var c in categories)
                                    {
                                        <option value="@c.CategoryID">@c.CategoryName</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <div class="form-check">
                                    <input type="checkbox" name="NewsStatus" value="true" class="form-check-input"
                                           id="createNewsStatus" checked />
                                    <label class="form-check-label" for="createNewsStatus">Active</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tags</label>
                                <div class="border rounded-3 p-3" style="max-height:200px;overflow-y:auto;">
                                    @foreach (var tag in tags)
                                    {
                                        <div class="form-check">
                                            <input type="checkbox" name="selectedTags" value="@tag.TagID"
                                                   class="form-check-input" id="ctag_@tag.TagID" />
                                            <label class="form-check-label" for="ctag_@tag.TagID">@tag.TagName</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-create">
                        <i class="bi bi-check-lg me-2"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit News Modal -->
<div class="modal fade modal-modern" id="editNewsModal" tabindex="-1" aria-labelledby="editNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form asp-action="EditNews" method="post" id="editNewsForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editNewsId" name="NewsArticleID" />
                <input type="hidden" id="editNewsCreatedById" name="CreatedByID" />
                <input type="hidden" id="editNewsCreatedDate" name="CreatedDate" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editNewsModalLabel"><i class="bi bi-pencil me-2"></i>Edit News Article</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editNewsModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Loading article data...</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-create">
                        <i class="bi bi-check-lg me-2"></i>Update
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade modal-modern" id="deleteNewsModal" tabindex="-1" aria-labelledby="deleteNewsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="DeleteNews" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteNewsId" name="id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteNewsModalLabel"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p>Are you sure you want to delete:</p>
                    <p><strong id="deleteNewsTitle"></strong></p>
                    <p class="text-danger small"><i class="bi bi-exclamation-circle me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-2"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var categoriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        categories.Select(c => new { id = c.CategoryID, name = c.CategoryName })));
    var tagsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        tags.Select(t => new { id = t.TagID, name = t.TagName })));

    function loadEditNewsModal(newsId) {
        var modal = new bootstrap.Modal(document.getElementById('editNewsModal'));
        document.getElementById('editNewsModalBody').innerHTML =
            '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Loading...</p></div>';
        modal.show();

        fetch('/Staff/GetNewsJson?id=' + encodeURIComponent(newsId))
            .then(r => r.json())
            .then(data => {
                document.getElementById('editNewsId').value = data.newsArticleID;
                document.getElementById('editNewsCreatedById').value = data.createdByID ?? '';
                document.getElementById('editNewsCreatedDate').value = data.createdDate ?? '';
                renderEditBody(data);
            })
            .catch(() => {
                document.getElementById('editNewsModalBody').innerHTML =
                    '<div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i>Failed to load article data. Please try again.</div>';
            });
    }

    function renderEditBody(data) {
        var catOptions = categoriesData.map(c =>
            `<option value="${c.id}" ${data.categoryID == c.id ? 'selected' : ''}>${c.name}</option>`
        ).join('');

        var tagChecks = tagsData.map(t =>
            `<div class="form-check">
                <input type="checkbox" name="selectedTags" value="${t.id}"
                       class="form-check-input" id="etag_${t.id}"
                       ${data.tagIds && data.tagIds.includes(t.id) ? 'checked' : ''} />
                <label class="form-check-label" for="etag_${t.id}">${t.name}</label>
             </div>`
        ).join('');

        document.getElementById('editNewsModalBody').innerHTML = `
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" name="NewsTitle" class="form-control form-control-modern" required maxlength="400"
                               value="${escHtml(data.newsTitle ?? '')}" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Headline <span class="text-danger">*</span></label>
                        <input type="text" name="Headline" class="form-control form-control-modern" required maxlength="150"
                               value="${escHtml(data.headline ?? '')}" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="NewsContent" class="form-control form-control-modern" rows="8" maxlength="4000">${escHtml(data.newsContent ?? '')}</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source</label>
                        <input type="text" name="NewsSource" class="form-control form-control-modern" maxlength="400"
                               value="${escHtml(data.newsSource ?? '')}" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Category <span class="text-danger">*</span></label>
                        <select name="CategoryID" class="form-select form-select-modern" required>
                            <option value="">-- Select Category --</option>
                            ${catOptions}
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" name="NewsStatus" value="true" class="form-check-input"
                                   id="editNewsStatus" ${data.newsStatus ? 'checked' : ''} />
                            <label class="form-check-label" for="editNewsStatus">Active</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <div class="border rounded-3 p-3" style="max-height:200px;overflow-y:auto;">
                            ${tagChecks}
                        </div>
                    </div>
                </div>
            </div>`;
    }

    function openDeleteNewsModal(id, title) {
        document.getElementById('deleteNewsId').value = id;
        document.getElementById('deleteNewsTitle').textContent = title;
        new bootstrap.Modal(document.getElementById('deleteNewsModal')).show();
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
</script>
}
