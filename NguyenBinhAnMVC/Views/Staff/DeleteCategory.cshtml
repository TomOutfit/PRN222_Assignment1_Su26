@model NguyenBinhAn_A01_Data.Models.Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="row">
    <div class="col-md-6">
        <h1>Delete Category</h1>
        
        <div class="alert alert-warning">
            <h3>Are you sure you want to delete this category?</h3>
            <p>This action cannot be undone.</p>
        </div>
        
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Name:</dt>
                    <dd class="col-sm-9">@Model.CategoryName</dd>
                    
                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">@Model.CategoryDescription</dd>
                    
                    <dt class="col-sm-3">Parent Category:</dt>
                    <dd class="col-sm-9">
                        @if (Model.ParentCategoryID.HasValue)
                        {
                            <span>Parent ID: @Model.ParentCategoryID</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                </dl>
                
                <form asp-action="DeleteCategoryConfirmed" method="post">
                    <input type="hidden" asp-for="CategoryID" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Categories" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
