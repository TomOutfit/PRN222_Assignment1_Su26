@model NguyenBinhAn_A01_Data.Models.SystemAccount
@{
    ViewData["Title"] = "My Profile";
    var roleLabel = Model.AccountRole switch {
        0 => "Admin",
        1 => "Staff",
        _ => "Lecturer"
    };
}

<style>
    .staff-title-section {
        margin-bottom: 30px;
    }
    
    .staff-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .btn-staff-primary {
        background: var(--theme-staff-gradient);
        color: white;
        border: none;
        font-weight: 700;
        padding: 12px 28px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px var(--theme-staff-glow);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-staff-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px var(--theme-staff-glow);
        color: white;
    }

    .btn-staff-secondary {
        background: #ffffff;
        color: #475569;
        border: 2.5px solid #e2e8f0;
        font-weight: 700;
        padding: 10px 22px;
        border-radius: 12px;
        transition: var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-staff-secondary:hover {
        border-color: #10b981;
        color: #10b981;
        transform: translateX(-3px);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1);
    }

    .profile-card {
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

    .profile-header-block {
        background: var(--theme-staff-gradient);
        padding: 40px 30px;
        text-align: center;
        position: relative;
        color: white;
        box-shadow: 0 8px 25px var(--theme-staff-glow);
    }

    .profile-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        border: 3px solid rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 38px;
        color: white;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
    }

    .profile-name {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 4px;
        letter-spacing: -0.25px;
    }

    .profile-role-badge {
        display: inline-block;
        padding: 5px 16px;
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .profile-info-list {
        list-style: none;
        padding: 25px 30px;
        margin: 0;
    }

    .profile-info-list li {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border-color);
    }

    .profile-info-list li:last-child {
        border-bottom: none;
    }

    .profile-info-list .info-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .profile-info-list .info-label {
        font-size: 0.76rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 2px;
        font-weight: 700;
    }

    .profile-info-list .info-value {
        font-weight: 700;
        color: #0f172a;
    }

    .form-section-title {
        font-weight: 800;
        color: #0f172a;
        font-size: 1.15rem;
        letter-spacing: -0.25px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-label-custom {
        font-weight: 700;
        color: #334155;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-hint {
        font-size: 12.5px;
        color: #64748b;
        margin-top: 6px;
        font-weight: 500;
    }

    .btn-cancel {
        border-radius: 12px;
        padding: 12px 28px;
        font-weight: 700;
        border: 2.5px solid #e2e8f0;
        color: #475569;
        background: white;
        transition: var(--transition-base);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="staff-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h1><i class="bi bi-person-badge-fill me-3 text-success"></i>My Profile</h1>
            <a asp-action="Dashboard" class="btn-staff-secondary">
                <i class="bi bi-arrow-left"></i>Back to Dashboard
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #dcfce7; color: #15803d; font-weight: 600;">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">
            <!-- Profile Info Card -->
            <div class="col-lg-4">
                <div class="profile-card">
                    <div class="profile-header-block">
                        <div class="profile-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="profile-name">@Model.AccountName</div>
                        <div class="profile-role-badge">@roleLabel</div>
                    </div>
                    <ul class="profile-info-list">
                        <li>
                            <div class="info-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <div>
                                <div class="info-label">Email Address</div>
                                <div class="info-value">@Model.AccountEmail</div>
                            </div>
                        </li>
                        <li>
                            <div class="info-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                                <i class="bi bi-shield-lock-fill"></i>
                            </div>
                            <div>
                                <div class="info-label">Account Role</div>
                                <div class="info-value">@roleLabel</div>
                            </div>
                        </li>
                        <li>
                            <div class="info-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                                <i class="bi bi-key-fill"></i>
                            </div>
                            <div>
                                <div class="info-label">Password Status</div>
                                <div class="info-value">
                                    <span class="text-success font-weight-bold"><i class="bi bi-check-circle-fill me-1"></i>Secure</span>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Edit Form Card -->
            <div class="col-lg-8">
                <div class="card-modern">
                    <div class="card-body p-4">
                        <h5 class="form-section-title"><i class="bi bi-pencil-square text-success"></i>Edit Profile Information</h5>
                        
                        <form asp-action="Profile" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="AccountID" />

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label-custom">Full Name <span class="text-danger">*</span></label>
                                        <input asp-for="AccountName" class="form-control-modern w-100"
                                               placeholder="Enter your name" />
                                        <span asp-validation-for="AccountName" class="text-danger small font-weight-semibold mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label-custom">Email Address</label>
                                        <input asp-for="AccountEmail" class="form-control-modern w-100" disabled />
                                        <div class="form-hint"><i class="bi bi-lock-fill me-1"></i>Email address is locked and cannot be changed</div>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4" style="border-color: var(--border-color); border-width: 2px;" />

                            <div class="mb-4">
                                <label class="form-label-custom">
                                    <i class="bi bi-key-fill me-1 text-success"></i>New Password
                                </label>
                                <input asp-for="AccountPassword" class="form-control-modern w-100"
                                       type="password" placeholder="Enter new password or leave blank to keep current" />
                                <span asp-validation-for="AccountPassword" class="text-danger small font-weight-semibold mt-1 d-block"></span>
                                <div class="form-hint">
                                    <i class="bi bi-info-circle-fill me-1"></i>Leave blank if you don't want to change your password
                                </div>
                            </div>

                            <hr class="my-4" style="border-color: var(--border-color); border-width: 2px;" />

                            <div class="d-flex gap-3 align-items-center">
                                <button type="submit" class="btn-staff-primary">
                                    <i class="bi bi-check-lg me-2"></i>Save Changes
                                </button>
                                <a asp-action="Dashboard" class="btn-cancel">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
