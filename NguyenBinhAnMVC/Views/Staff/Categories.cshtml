@model IEnumerable<NguyenBinhAn_A01_Data.Models.Category>
@{
    ViewData["Title"] = "Manage Categories";
    var parentCategories = ViewBag.ParentCategories as IEnumerable<NguyenBinhAn_A01_Data.Models.Category>
                           ?? Enumerable.Empty<NguyenBinhAn_A01_Data.Models.Category>();
}

<style>
    .staff-title-section {
        margin-bottom: 30px;
    }
    
    .staff-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .btn-staff-primary {
        background: var(--theme-staff-gradient);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px var(--theme-staff-glow);
    }

    .btn-staff-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px var(--theme-staff-glow);
        color: white;
    }

    .btn-staff-danger {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px rgba(220, 38, 38, 0.2);
    }

    .btn-staff-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.3);
        color: white;
    }

    .btn-action-edit {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #e2e8f0;
        color: #475569;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-edit:hover {
        background: var(--theme-staff-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px var(--theme-staff-glow);
    }

    .btn-action-delete {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #fee2e2;
        color: #ef4444;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-delete:hover {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .search-wrapper .form-control-modern {
        border-radius: 12px 0 0 12px !important;
        border-right: none;
    }

    .search-wrapper .btn-search {
        border-radius: 0 12px 12px 0;
        border: 2.5px solid var(--border-color);
        background: #f8fafc;
        color: #475569;
        font-weight: 700;
        padding: 0 20px;
        transition: var(--transition-base);
    }

    .search-wrapper .btn-search:hover {
        background: #f1f5f9;
        color: #0f172a;
    }

    .search-wrapper .btn-clear {
        border-radius: 12px;
        margin-left: 10px;
        font-weight: 700;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
    }

    .pagination-info strong {
        color: #10b981;
    }

    .modal-modern .modal-content {
        border: none;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    }

    .modal-modern .modal-header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .modal-header .modal-title {
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.25px;
    }

    .modal-modern .modal-body {
        padding: 2rem;
    }

    .modal-modern .modal-footer {
        border-top: 1px solid var(--border-color);
        padding: 1.25rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .form-label {
        font-weight: 700;
        color: #334155;
        font-size: 14px;
        margin-bottom: 8px;
    }
</style>

<div class="staff-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
    <h1><i class="bi bi-folder-fill me-3 text-success"></i>Manage Categories</h1>
    <button type="button" class="btn-staff-primary" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
        <i class="bi bi-folder-plus me-2"></i>Create New Category
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #dcfce7; color: #15803d; font-weight: 600;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #fee2e2; color: #b91c1c; font-weight: 600;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-modern">
    <div class="card-body p-4">
        <form asp-action="Categories" method="get" class="mb-4">
            <div class="input-group search-wrapper">
                <input type="text" name="searchTerm" class="form-control-modern w-auto flex-grow-1"
                       placeholder="Search by name or description..."
                       value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn-search"><i class="bi bi-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <a asp-action="Categories" class="btn btn-outline-secondary btn-clear px-4 py-2 d-flex align-items-center">
                        <i class="bi bi-x-circle me-2"></i>Clear
                    </a>
                }
            </div>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="alert alert-light border shadow-none mb-3 d-inline-block px-3 py-2" style="border-radius: 8px; font-weight: 600; font-size: 14px; background: #f8fafc;">
                <i class="bi bi-search me-2 text-success"></i>Results for: "<strong>@ViewBag.SearchTerm</strong>" — <strong>@ViewBag.TotalItems</strong> found
            </div>
        }

        @if (!Model.Any())
        {
            <div class="alert alert-info border-0 p-4 text-center bg-light text-muted" style="border-radius: 12px; font-weight: 600;">
                <i class="bi bi-info-circle display-4 mb-3 d-block"></i>No categories found.
            </div>
        }
        else
        {
            <div class="table-modern-wrapper">
                <table class="table-modern w-100">
                    <thead>
                        <tr>
                            <th style="width: 25%">Name</th>
                            <th style="width: 40%">Description</th>
                            <th style="width: 15%">Parent</th>
                            <th style="width: 10%">Status</th>
                            <th style="width: 10%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td class="font-weight-bold" style="color: #0f172a;">@cat.CategoryName</td>
                                <td style="color: #475569; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @(cat.CategoryDescription?.Length > 80
                                        ? cat.CategoryDescription.Substring(0, 80) + "…"
                                        : cat.CategoryDescription ?? "-")
                                </td>
                                <td>
                                    @if (cat.ParentCategoryID.HasValue)
                                    {
                                        var parentName = parentCategories.FirstOrDefault(p => p.CategoryID == cat.ParentCategoryID)?.CategoryName;
                                        <span class="badge-modern badge-modern-secondary">@(parentName ?? $"ID:{cat.ParentCategoryID}")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted font-weight-bold" style="font-size: 12.5px;"><i class="bi bi-node-plus-fill me-1 text-success"></i>Root</span>
                                    }
                                </td>
                                <td>
                                    @if (cat.IsActive == true)
                                    {
                                        <span class="badge-modern badge-modern-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-modern-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn-action-edit"
                                                onclick="openEditCategoryModal(@cat.CategoryID,
                                                    '@Html.Raw(cat.CategoryName.Replace("'", "\\'"))',
                                                    '@Html.Raw(cat.CategoryDescription?.Replace("'", "\\'") ?? "")',
                                                    '@cat.ParentCategoryID',
                                                    '@(cat.IsActive == true ? "true" : "false")')">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </button>
                                        <button type="button" class="btn-action-delete"
                                                onclick="openDeleteCategoryModal(@cat.CategoryID, '@Html.Raw(cat.CategoryName.Replace("'", "\\'"))')">
                                            <i class="bi bi-trash-fill me-1"></i>Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                var totalPages = (int)(ViewBag.TotalPages ?? 1);
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);

                <div class="pagination-wrapper">
                    <div class="pagination-info">
                        Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                        to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                        of <strong>@ViewBag.TotalItems</strong> categories
                    </div>
                    <nav aria-label="Categories pagination">
                        <ul class="pagination pagination-modern mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Categories" asp-route-page="1" asp-route-searchTerm="@ViewBag.SearchTerm" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Categories" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Previous">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Categories" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Categories" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Next">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Categories" asp-route-page="@totalPages" asp-route-searchTerm="@ViewBag.SearchTerm" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<!-- ── Create Category Modal ────────────────────────────────────────── -->
<div class="modal modal-modern fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="CreateCategory" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createCategoryModalLabel"><i class="bi bi-folder-plus text-success me-2"></i>Create New Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" name="CategoryName" class="form-control-modern w-100" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="CategoryDescription" class="form-control-modern w-100" rows="3" maxlength="250"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Parent Category</label>
                        <select name="ParentCategoryID" class="form-select-modern w-100">
                            <option value="">None (Root Category)</option>
                            @foreach (var p in parentCategories)
                            {
                                <option value="@p.CategoryID">@p.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-1">
                        <div class="form-check d-flex align-items-center gap-2">
                            <input type="checkbox" name="IsActive" value="true" class="form-check-input mt-0" id="createIsActive" checked />
                            <label class="form-check-label font-weight-bold text-dark mb-0" for="createIsActive" style="font-size: 14.5px;">Active Status</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-primary">Create Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Edit Category Modal ───────────────────────────────────────────── -->
<div class="modal modal-modern fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editCategoryId" name="CategoryID" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editCategoryModalLabel"><i class="bi bi-pencil-square text-success me-2"></i>Edit Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" id="editCategoryName" name="CategoryName" class="form-control-modern w-100" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="editCategoryDesc" name="CategoryDescription" class="form-control-modern w-100" rows="3" maxlength="250"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Parent Category</label>
                        <select id="editParentCategoryID" name="ParentCategoryID" class="form-select-modern w-100">
                            <option value="">None (Root Category)</option>
                            @foreach (var p in parentCategories)
                            {
                                <option value="@p.CategoryID">@p.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-1">
                        <div class="form-check d-flex align-items-center gap-2">
                            <input type="checkbox" id="editIsActive" name="IsActive" value="true" class="form-check-input mt-0" />
                            <label class="form-check-label font-weight-bold text-dark mb-0" for="editIsActive" style="font-size: 14.5px;">Active Status</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Delete Confirmation Modal ─────────────────────────────────────── -->
<div class="modal modal-modern fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <form asp-action="DeleteCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteCategoryId" name="id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteCategoryModalLabel" style="color: white;"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-trash-fill text-danger display-4 mb-3 d-block"></i>
                    <h5 class="font-weight-bold text-dark mb-3">Are you sure you want to delete this category?</h5>
                    <div class="p-3 mb-3 border" style="border-radius: 12px; background-color: #f8fafc;">
                        <h6 class="font-weight-bold mb-0" id="deleteCategoryName"></h6>
                    </div>
                    <p class="text-danger font-weight-bold mb-0"><i class="bi bi-info-circle-fill me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-staff-danger">Yes, Delete Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openEditCategoryModal(id, name, desc, parentId, isActive) {
        document.getElementById('editCategoryId').value = id;
        document.getElementById('editCategoryName').value = name;
        document.getElementById('editCategoryDesc').value = desc;
        var parentSel = document.getElementById('editParentCategoryID');
        parentSel.value = (parentId && parentId !== 'null' && parentId !== '') ? parentId : '';
        document.getElementById('editIsActive').checked = (isActive === 'true');
        new bootstrap.Modal(document.getElementById('editCategoryModal')).show();
    }

    function openDeleteCategoryModal(id, name) {
        document.getElementById('deleteCategoryId').value = id;
        document.getElementById('deleteCategoryName').textContent = name;
        new bootstrap.Modal(document.getElementById('deleteCategoryModal')).show();
    }

    @if (ViewBag.ShowCreateModal == true)
    {
        <text>
        window.addEventListener('DOMContentLoaded', function () {
            new bootstrap.Modal(document.getElementById('createCategoryModal')).show();
        });
        </text>
    }
</script>
}
