@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = Model.NewsTitle;
}

<style>
    /* ── Breadcrumb ── */
    .breadcrumb-custom {
        background: transparent;
        padding: 0;
        margin-bottom: 0;
    }
    .breadcrumb-custom .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
        font-weight: 500;
    }
    .breadcrumb-custom .breadcrumb-item.active {
        color: #888;
    }
    .breadcrumb-custom .breadcrumb-item + .breadcrumb-item::before {
        color: #ccc;
    }

    /* ── Article Hero Banner ── */
    .article-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px 0 60px;
        margin-bottom: 50px;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }
    .article-hero::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -5%;
        width: 350px;
        height: 350px;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 50%;
    }
    .article-hero::after {
        content: '';
        position: absolute;
        bottom: -40%;
        left: 10%;
        width: 250px;
        height: 250px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
    }
    .article-hero .breadcrumb-custom .breadcrumb-item a,
    .article-hero .breadcrumb-custom .breadcrumb-item {
        color: rgba(255, 255, 255, 0.8);
    }
    .article-hero .breadcrumb-custom .breadcrumb-item a:hover {
        color: white;
    }
    .article-hero .breadcrumb-custom .breadcrumb-item.active {
        color: rgba(255, 255, 255, 0.5);
    }
    .article-hero .breadcrumb-item + .breadcrumb-item::before {
        color: rgba(255, 255, 255, 0.4) !important;
    }

    /* ── Article Title Block ── */
    .article-category-badge {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        color: white;
        border-radius: 25px;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.5px;
        margin-bottom: 18px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .article-title {
        font-size: 2.2rem;
        font-weight: 700;
        line-height: 1.3;
        color: white;
        margin-bottom: 16px;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
    }
    .article-headline {
        font-size: 1.15rem;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.6;
        margin-bottom: 0;
        font-weight: 400;
    }
    .article-meta {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: 25px;
        flex-wrap: wrap;
    }
    .article-meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.75);
    }
    .article-meta-item i {
        font-size: 1rem;
        opacity: 0.8;
    }
    .article-meta-item .author-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    /* ── Article Body ── */
    .article-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .article-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
        overflow: hidden;
    }
    .article-body {
        padding: 40px 50px;
        font-size: 1.05rem;
        line-height: 1.9;
        color: #3a3a4a;
    }
    .article-body p {
        margin-bottom: 1.4rem;
    }
    .article-content {
        font-size: 1.05rem;
        line-height: 1.9;
        color: #3a3a4a;
    }
    .article-content p {
        margin-bottom: 1.4rem;
    }

    /* ── Share Section ── */
    .article-share {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 25px 50px;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
        flex-wrap: wrap;
    }
    .share-label {
        font-weight: 600;
        color: #1a1a2e;
        font-size: 14px;
        margin-right: 5px;
    }
    .share-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.3s ease;
        font-size: 16px;
        text-decoration: none;
    }
    .share-btn-facebook {
        background: #e8f0fe;
        color: #4267B2;
    }
    .share-btn-facebook:hover {
        background: #4267B2;
        color: white;
        transform: translateY(-2px);
    }
    .share-btn-twitter {
        background: #e8f5f9;
        color: #1DA1F2;
    }
    .share-btn-twitter:hover {
        background: #1DA1F2;
        color: white;
        transform: translateY(-2px);
    }
    .share-btn-linkedin {
        background: #e8f0f5;
        color: #0077B5;
    }
    .share-btn-linkedin:hover {
        background: #0077B5;
        color: white;
        transform: translateY(-2px);
    }
    .share-btn-copy {
        background: #f0f0f0;
        color: #555;
        cursor: pointer;
    }
    .share-btn-copy:hover {
        background: #667eea;
        color: white;
        transform: translateY(-2px);
    }

    /* ── Source / Footer ── */
    .article-footer {
        padding: 25px 50px;
    }
    .source-block {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: #f8f9fa;
        border-radius: 12px;
        border-left: 4px solid #667eea;
    }
    .source-block i {
        font-size: 1.2rem;
        color: #667eea;
    }
    .source-block .source-label {
        font-size: 12px;
        color: #888;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .source-block .source-text {
        font-size: 14px;
        color: #333;
        font-weight: 500;
        margin: 0;
    }

    /* ── Back Button ── */
    .article-actions {
        padding: 20px 50px 35px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        background: white;
        color: #555;
        font-weight: 500;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .btn-back:hover {
        border-color: #667eea;
        color: #667eea;
        transform: translateX(-3px);
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.15);
    }
    .btn-back i {
        transition: transform 0.3s;
    }
    .btn-back:hover i {
        transform: translateX(-3px);
    }

    /* ── Related Articles ── */
    .related-section {
        margin-top: 60px;
        margin-bottom: 20px;
    }
    .related-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .related-title i {
        color: #667eea;
    }
    .related-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }
    .related-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }
    .related-card .card-body {
        padding: 22px;
    }
    .related-card .card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1a1a2e;
        line-height: 1.4;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .related-card .card-title a {
        color: inherit;
        text-decoration: none;
        transition: color 0.3s;
    }
    .related-card .card-title a:hover {
        color: #667eea;
    }
    .related-card .card-text {
        font-size: 0.88rem;
        color: #888;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 12px;
    }
    .related-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 12px;
        color: #aaa;
    }
    .related-meta i {
        margin-right: 4px;
    }
    .related-card .read-link {
        font-size: 13px;
        font-weight: 500;
        color: #667eea;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: gap 0.3s;
    }
    .related-card:hover .read-link {
        gap: 8px;
    }

    /* ── Reading Progress ── */
    .reading-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        z-index: 9999;
        transition: width 0.1s linear;
    }

    /* ── Info Chips ── */
    .info-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .info-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: rgba(102, 126, 234, 0.08);
        color: #667eea;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .article-hero {
            padding: 30px 0 45px;
            border-radius: 0 0 20px 20px;
        }
        .article-title {
            font-size: 1.6rem;
        }
        .article-headline {
            font-size: 1rem;
        }
        .article-body {
            padding: 25px 22px;
        }
        .article-share,
        .article-footer,
        .article-actions {
            padding-left: 22px;
            padding-right: 22px;
        }
        .article-meta {
            gap: 12px;
        }
    }
</style>

<!-- Reading Progress Bar -->
<div class="reading-progress" id="readingProgress"></div>

<!-- Article Hero Banner -->
<div class="article-hero">
    <div class="container">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="breadcrumb-custom mb-4">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Home</a>
                </li>
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">News</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    @(Model.NewsTitle?.Length > 40 ? Model.NewsTitle.Substring(0, 40) + "..." : Model.NewsTitle)
                </li>
            </ol>
        </nav>

        <!-- Category Badge -->
        @if (ViewBag.Category != null)
        {
            <span class="article-category-badge">
                <i class="bi bi-folder-fill me-1"></i>@ViewBag.Category.CategoryName
            </span>
        }

        <!-- Title -->
        <h1 class="article-title">@Model.NewsTitle</h1>

        <!-- Headline -->
        @if (!string.IsNullOrEmpty(Model.Headline))
        {
            <p class="article-headline">@Model.Headline</p>
        }

        <!-- Meta Info -->
        <div class="article-meta">
            <div class="article-meta-item">
                <div class="author-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <span>Staff Member</span>
            </div>
            <div class="article-meta-item">
                <i class="bi bi-calendar3"></i>
                <span>@(Model.CreatedDate?.ToString("MMMM dd, yyyy") ?? "N/A")</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.NewsSource))
            {
                <div class="article-meta-item">
                    <i class="bi bi-newspaper"></i>
                    <span>@Model.NewsSource</span>
                </div>
            }
            <div class="article-meta-item">
                <i class="bi bi-clock"></i>
                <span>@(Model.CreatedDate?.ToString("HH:mm") ?? "")</span>
            </div>
        </div>
    </div>
</div>

<!-- Article Content -->
<div class="container">
    <div class="article-container">

        <!-- Article Card -->
        <div class="article-card">
            
            <!-- Main Content -->
            <div class="article-body">
                <div class="article-content">
                    @if (!string.IsNullOrEmpty(Model.NewsContent))
                    {
                        @Html.Raw((Model.NewsContent ?? "").Replace("\n", "</p><p>"))
                    }
                    else
                    {
                        <p class="text-muted fst-italic">No content available for this article.</p>
                    }
                </div>
            </div>

            <!-- Share Section -->
            <div class="article-share">
                <span class="share-label"><i class="bi bi-share me-1"></i>Share:</span>
                <a href="https://www.facebook.com/sharer/sharer.php?u=@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" target="_blank" class="share-btn share-btn-facebook" title="Share on Facebook">
                    <i class="bi bi-facebook"></i>
                </a>
                <a href="https://twitter.com/intent/tweet?url=@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path&text=@Model.NewsTitle" target="_blank" class="share-btn share-btn-twitter" title="Share on X (Twitter)">
                    <i class="bi bi-twitter-x"></i>
                </a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&url=@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" target="_blank" class="share-btn share-btn-linkedin" title="Share on LinkedIn">
                    <i class="bi bi-linkedin"></i>
                </a>
                <button onclick="copyLink()" class="share-btn share-btn-copy" title="Copy Link" id="copyBtn">
                    <i class="bi bi-link-45deg"></i>
                </button>

                <!-- Info Chips -->
                <div class="info-chips ms-auto">
                    @if (ViewBag.Category != null)
                    {
                        <span class="info-chip">
                            <i class="bi bi-tag"></i>@ViewBag.Category.CategoryName
                        </span>
                    }
                    @if (Model.CreatedDate.HasValue)
                    {
                        <span class="info-chip">
                            <i class="bi bi-calendar-event"></i>@Model.CreatedDate.Value.ToString("MMM dd, yyyy")
                        </span>
                    }
                </div>
            </div>

            <!-- Source Block -->
            @if (!string.IsNullOrEmpty(Model.NewsSource))
            {
                <div class="article-footer">
                    <div class="source-block">
                        <i class="bi bi-box-arrow-up-right"></i>
                        <div>
                            <p class="source-label mb-1">News Source</p>
                            <p class="source-text mb-0">@Model.NewsSource</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Actions: Back + Related -->
            <div class="article-actions">
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left"></i>Back to News
                </a>
                
                @if (Model.ModifiedDate.HasValue)
                {
                    <small class="text-muted">
                        <i class="bi bi-pencil-square me-1"></i>
                        Updated: @(Model.ModifiedDate?.ToString("MMM dd, yyyy HH:mm"))
                    </small>
                }
            </div>
        </div>

        <!-- Related Articles Placeholder -->
        @if (ViewBag.RelatedNews != null && ((IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>)ViewBag.RelatedNews).Any())
        {
            <div class="related-section">
                <h3 class="related-title">
                    <i class="bi bi-bookmark-star-fill"></i>Related Articles
                </h3>
                <div class="row g-4">
                    @foreach (var related in ((IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>)ViewBag.RelatedNews).Take(3))
                    {
                        <div class="col-md-4">
                            <div class="related-card">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <a asp-action="Details" asp-route-id="@related.NewsArticleID">
                                            @related.NewsTitle
                                        </a>
                                    </h5>
                                    @if (!string.IsNullOrEmpty(related.Headline))
                                    {
                                        <p class="card-text">@related.Headline</p>
                                    }
                                    <div class="related-meta">
                                        <span>
                                            <i class="bi bi-calendar3"></i>@(related.CreatedDate?.ToString("MMM dd") ?? "N/A")
                                        </span>
                                        <a asp-action="Details" asp-route-id="@related.NewsArticleID" class="read-link">
                                            Read <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    // Copy Link
    var currentUrl = window.location.href;
    function copyLink() {
        navigator.clipboard.writeText(currentUrl).then(() => {
            const btn = document.getElementById('copyBtn');
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check"></i>';
            btn.style.background = '#28a745';
            btn.style.color = 'white';
            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.style.background = '';
                btn.style.color = '';
            }, 2000);
        });
    }

    // Reading Progress Bar
    window.addEventListener('scroll', function() {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollTop = window.scrollY;
        const progress = (scrollTop / docHeight) * 100;
        document.getElementById('readingProgress').style.width = progress + '%';
    });
</script>
