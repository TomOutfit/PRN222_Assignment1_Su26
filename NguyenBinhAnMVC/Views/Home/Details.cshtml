@model NguyenBinhAn_A01_Data.Models.NewsArticle
@{
    ViewData["Title"] = Model.NewsTitle;
}

<div class="row">
    <div class="col-md-12">
        <article>
            <header>
                <h1>@Model.NewsTitle</h1>
                <div class="text-muted mb-3">
                    <small>
                        @(Model.CreatedDate?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A") | 
                        Category ID: @Model.CategoryID
                    </small>
                </div>
            </header>
            
            @if (!string.IsNullOrEmpty(Model.Headline))
            {
                <div class="lead mb-3">
                    <p>@Model.Headline</p>
                </div>
            }
            
            <div class="news-content">
                @Html.Raw((Model.NewsContent ?? "").Replace("\n", "<br/>"))
            </div>
            
            @if (!string.IsNullOrEmpty(Model.NewsSource))
            {
                <footer class="mt-4">
                    <small class="text-muted">
                        Source: @Model.NewsSource
                    </small>
                </footer>
            }
            
            @if (Model.ModifiedDate.HasValue)
            {
                <footer class="mt-2">
                    <small class="text-muted">
                        Last updated: @(Model.ModifiedDate?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")
                        @if (Model.UpdatedByID.HasValue)
                        {
                            @: by User ID: @Model.UpdatedByID
                        }
                    </small>
                </footer>
            }
        </article>
        
        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary">Back to News</a>
        </div>
    </div>
</div>
