@model IEnumerable<NguyenBinhAn_A01_Data.Models.NewsArticle>
@{
    ViewData["Title"] = "News Articles";
}

<style>
    .hero-section {
        background: var(--theme-public-gradient);
        color: white;
        padding: 60px 0;
        margin-bottom: 40px;
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px var(--theme-public-glow);
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -5%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }
    
    .hero-section h1 {
        font-weight: 800;
        font-size: 2.6rem;
        letter-spacing: -0.5px;
    }
    
    .hero-section p {
        opacity: 0.9;
        font-weight: 500;
    }
    
    .news-card {
        border: 1px solid rgba(226, 232, 240, 0.7);
        background: #ffffff;
        border-radius: var(--radius-lg);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        transition: var(--transition-base);
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    
    .news-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 35px rgba(99, 102, 241, 0.08);
        border-color: rgba(99, 102, 241, 0.2);
    }
    
    .news-card .card-body {
        padding: 30px;
        display: flex;
        flex-direction: column;
        height: 100%;
        justify-content: space-between;
    }
    
    .news-card .category-badge {
        display: inline-block;
        padding: 5px 14px;
        background: rgba(99, 102, 241, 0.08);
        color: #4f46e5;
        border-radius: 50px;
        font-size: 11.5px;
        font-weight: 700;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .news-card .card-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 12px;
        line-height: 1.45;
        letter-spacing: -0.25px;
    }
    
    .news-card .card-title a {
        color: inherit;
        text-decoration: none;
        transition: var(--transition-base);
    }
    
    .news-card .card-title a:hover {
        color: #4f46e5;
    }
    
    .news-card .card-text {
        color: #475569;
        font-size: 0.95rem;
        line-height: 1.65;
        font-weight: 500;
        margin-bottom: 20px;
    }
    
    .news-card .meta-info {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 13px;
        color: #64748b;
        margin-top: auto;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
    }
    
    .news-card .meta-info span {
        display: inline-flex;
        align-items: center;
        font-weight: 600;
    }

    .news-card .meta-info i {
        margin-right: 6px;
        color: #94a3b8;
    }
    
    .news-card .read-btn {
        border-radius: 50px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 16px;
        border: 2px solid #e2e8f0;
        transition: var(--transition-base);
        color: #475569;
        background: transparent;
    }

    .news-card:hover .read-btn {
        background: var(--theme-public-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px var(--theme-public-glow);
    }
    
    .sidebar-card {
        border: 1px solid rgba(226, 232, 240, 0.7);
        border-radius: var(--radius-lg);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        overflow: hidden;
        background: white;
    }
    
    .sidebar-card .card-header {
        background: var(--theme-public-gradient);
        color: white;
        border: none;
        padding: 20px 24px;
        font-weight: 700;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
    }
    
    .sidebar-card .list-group-item {
        border: none;
        border-bottom: 1px solid var(--border-color);
        padding: 14px 24px;
        transition: var(--transition-base);
        color: #475569;
        font-weight: 600;
    }

    .sidebar-card .list-group-item:last-child {
        border-bottom: none;
    }
    
    .sidebar-card .list-group-item:hover {
        background: #f8fafc;
        color: #4f46e5;
    }
    
    .sidebar-card .list-group-item a {
        color: inherit;
        text-decoration: none;
        display: flex;
        width: 100%;
    }
    
    .search-form .form-control {
        border-radius: 12px;
        padding: 12px 18px;
        border: 2.5px solid #e2e8f0;
        transition: var(--transition-base);
        font-weight: 500;
    }
    
    .search-form .form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
    }
    
    .search-form .btn-search {
        border-radius: 12px;
        padding: 12px 20px;
        background: var(--theme-public-gradient);
        color: white;
        border: none;
        font-weight: 700;
        box-shadow: 0 4px 12px var(--theme-public-glow);
        transition: var(--transition-base);
    }

    .search-form .btn-search:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 18px var(--theme-public-glow);
    }
    
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #64748b;
    }
    
    .empty-state i {
        font-size: 70px;
        margin-bottom: 24px;
        opacity: 0.4;
        color: #6366f1;
    }
    
    .breadcrumb-custom {
        background: transparent;
        padding: 0;
        margin-bottom: 25px;
    }
    
    .breadcrumb-custom .breadcrumb-item a {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition-base);
    }

    .breadcrumb-custom .breadcrumb-item a:hover {
        color: #6366f1;
    }

    .breadcrumb-custom .breadcrumb-item.active {
        font-weight: 600;
        color: #64748b;
    }
    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
    }

    .pagination-info strong {
        color: #10b981;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-newspaper me-3"></i>Latest News</h1>
                <p class="mb-0">Stay informed with the latest updates and announcements from our community</p>
            </div>
            <div class="col-md-4 text-end">
                <div class="news-count">
                    <span class="badge bg-light text-dark fs-6 px-3 py-2">
                        <i class="bi bi-collection me-1"></i>@(ViewBag.TotalItems ?? 0) Articles
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Breadcrumb -->
@if (!string.IsNullOrEmpty(ViewBag.SearchTerm) || ViewBag.Category != null)
{
    <nav aria-label="breadcrumb" class="breadcrumb-custom">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            @if (ViewBag.Category != null)
            {
                <li class="breadcrumb-item active">@ViewBag.Category.CategoryName</li>
            }
            else if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <li class="breadcrumb-item active">Search Results</li>
            }
        </ol>
    </nav>
}

<div class="row">
    <div class="col-lg-8">
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <div class="alert alert-light border mb-4">
                <i class="bi bi-search me-2"></i>Search results for: "<strong>@ViewBag.SearchTerm</strong>"
            </div>
        }

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-newspaper"></i>
                <h4>No articles found</h4>
                <p>There are no news articles to display at the moment.</p>
                <a asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-2"></i>Back to all news
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var news in Model)
                {
                    <div class="col-md-6">
                        <div class="news-card">
                            <div class="card-body">
                                @if (ViewBag.Categories != null)
                                {
                                    var category = ((IEnumerable<NguyenBinhAn_A01_Data.Models.Category>)ViewBag.Categories)
                                        .FirstOrDefault(c => c.CategoryID == news.CategoryID);
                                    @if (category != null)
                                    {
                                        <span class="category-badge">@category.CategoryName</span>
                                    }
                                }
                                
                                <h5 class="card-title">
                                    <a asp-action="Details" asp-route-id="@news.NewsArticleID">
                                        @news.NewsTitle
                                    </a>
                                </h5>
                                
                                @if (!string.IsNullOrEmpty(news.Headline))
                                {
                                    <p class="card-text">@news.Headline</p>
                                }
                                
                                <div class="meta-info">
                                    <span><i class="bi bi-calendar3"></i>@(news.CreatedDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                                    <a asp-action="Details" asp-route-id="@news.NewsArticleID" class="read-btn">
                                        Read More <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                var currentPage = (int)(ViewBag.CurrentPage ?? 1);
                var totalPages = (int)(ViewBag.TotalPages ?? 1);
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);
                var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

                <div class="pagination-wrapper">
                    <div class="pagination-info">
                        Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                        to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                        of <strong>@ViewBag.TotalItems</strong> articles
                    </div>
                    <nav aria-label="News pagination">
                        <ul class="pagination pagination-modern mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="@actionName" asp-route-page="1" asp-route-id="@(ViewBag.Category != null ? ViewBag.Category.CategoryID : null)" asp-route-searchTerm="@ViewBag.SearchTerm" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="@actionName" asp-route-page="@(currentPage - 1)" asp-route-id="@(ViewBag.Category != null ? ViewBag.Category.CategoryID : null)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Previous">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="@actionName" asp-route-page="@i" asp-route-id="@(ViewBag.Category != null ? ViewBag.Category.CategoryID : null)" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="@actionName" asp-route-page="@(currentPage + 1)" asp-route-id="@(ViewBag.Category != null ? ViewBag.Category.CategoryID : null)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Next">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="@actionName" asp-route-page="@totalPages" asp-route-id="@(ViewBag.Category != null ? ViewBag.Category.CategoryID : null)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
    
    <div class="col-lg-4">
        <!-- Categories Card -->
        <div class="sidebar-card mb-4">
            <div class="card-header">
                <i class="bi bi-grid-3x3-gap me-2"></i>Categories
            </div>
            <div class="list-group list-group-flush">
                <li class="list-group-item">
                    <a asp-action="Index" class="d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-collection me-2"></i>All Categories</span>
                        <span class="badge bg-light text-dark">@(ViewBag.TotalItems ?? 0)</span>
                    </a>
                </li>
                @if (ViewBag.Categories != null)
                {
                    @foreach (var category in (IEnumerable<NguyenBinhAn_A01_Data.Models.Category>)ViewBag.Categories)
                    {
                        <li class="list-group-item">
                            <a asp-action="Category" asp-route-id="@category.CategoryID">
                                <i class="bi bi-folder me-2"></i>@category.CategoryName
                            </a>
                        </li>
                    }
                }
            </div>
        </div>
        
        <!-- Search Card -->
        <div class="sidebar-card">
            <div class="card-header">
                <i class="bi bi-search me-2"></i>Search
            </div>
            <div class="card-body">
                <form asp-action="Search" method="get" class="search-form">
                    <div class="input-group">
                        <input type="text" name="searchTerm" class="form-control" 
                               placeholder="Search news..." value="@ViewBag.SearchTerm" />
                        <button type="submit" class="btn-search">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2 rounded-pill font-weight-bold">
                            <i class="bi bi-x-circle me-2"></i>Clear Search
                        </a>
                    }
                </form>
            </div>
        </div>
    </div>
</div>
