@model IEnumerable<NguyenBinhAn_A01_Data.Models.SystemAccount>
@{
    ViewData["Title"] = "Manage Accounts";
}

<style>
    .admin-title-section {
        margin-bottom: 30px;
    }
    
    .admin-title-section h1 {
        font-weight: 800;
        font-size: 2.2rem;
        letter-spacing: -0.5px;
        color: #0f172a;
        margin-bottom: 0;
    }

    .btn-admin-primary {
        background: var(--theme-admin-gradient);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px var(--theme-admin-glow);
    }

    .btn-admin-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px var(--theme-admin-glow);
        color: white;
    }

    .btn-admin-danger {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border: none;
        font-weight: 700;
        padding: 10px 24px;
        border-radius: 12px;
        transition: var(--transition-base);
        box-shadow: 0 4px 14px rgba(220, 38, 38, 0.2);
    }

    .btn-admin-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.3);
        color: white;
    }

    .btn-action-edit {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #e2e8f0;
        color: #475569;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-edit:hover {
        background: var(--theme-admin-gradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px var(--theme-admin-glow);
    }

    .btn-action-delete {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        padding: 6px 14px;
        border: 2px solid #fee2e2;
        color: #ef4444;
        background: white;
        transition: var(--transition-base);
    }

    .btn-action-delete:hover {
        background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .search-wrapper .form-control-modern {
        border-radius: 12px 0 0 12px !important;
        border-right: none;
    }

    .search-wrapper .btn-search {
        border-radius: 0 12px 12px 0;
        border: 2.5px solid var(--border-color);
        background: #f8fafc;
        color: #475569;
        font-weight: 700;
        padding: 0 20px;
        transition: var(--transition-base);
    }

    .search-wrapper .btn-search:hover {
        background: #f1f5f9;
        color: #0f172a;
    }

    .search-wrapper .btn-clear {
        border-radius: 12px;
        margin-left: 10px;
        font-weight: 700;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
    }

    .pagination-info strong {
        color: #dc2626;
    }

    .modal-modern .modal-content {
        border: none;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    }

    .modal-modern .modal-header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .modal-header .modal-title {
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.25px;
    }

    .modal-modern .modal-body {
        padding: 2rem;
    }

    .modal-modern .modal-footer {
        border-top: 1px solid var(--border-color);
        padding: 1.25rem 2rem;
        background: #f8fafc;
    }

    .modal-modern .form-label {
        font-weight: 700;
        color: #334155;
        font-size: 14px;
        margin-bottom: 8px;
    }
</style>

<div class="admin-title-section d-flex justify-content-between align-items-center flex-wrap gap-3">
    <h1><i class="bi bi-people-fill me-3 text-danger"></i>Manage Accounts</h1>
    <button type="button" class="btn-admin-primary" data-bs-toggle="modal" data-bs-target="#createAccountModal">
        <i class="bi bi-person-plus-fill me-2"></i>Create New Account
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #dcfce7; color: #15803d; font-weight: 600;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px; background-color: #fee2e2; color: #b91c1c; font-weight: 600;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-modern">
    <div class="card-body p-4">
        <form asp-action="Accounts" method="get" class="mb-4">
            <div class="input-group search-wrapper">
                <input type="text" name="searchTerm" class="form-control-modern w-auto flex-grow-1"
                       placeholder="Search by name or email..."
                       value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn-search"><i class="bi bi-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <a asp-action="Accounts" class="btn btn-outline-secondary btn-clear px-4 py-2 d-flex align-items-center">
                        <i class="bi bi-x-circle me-2"></i>Clear
                    </a>
                }
            </div>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="alert alert-light border shadow-none mb-3 d-inline-block px-3 py-2" style="border-radius: 8px; font-weight: 600; font-size: 14px; background: #f8fafc;">
                <i class="bi bi-search me-2 text-danger"></i>Results for: "<strong>@ViewBag.SearchTerm</strong>" — <strong>@ViewBag.TotalItems</strong> found
            </div>
        }

        <div class="table-modern-wrapper">
            <table class="table-modern w-100">
                <thead>
                    <tr>
                        <th style="width: 10%">ID</th>
                        <th style="width: 30%">Name</th>
                        <th style="width: 30%">Email</th>
                        <th style="width: 15%">Role</th>
                        <th style="width: 15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in Model)
                    {
                        <tr>
                            <td class="font-weight-bold" style="color: #64748b;">#@account.AccountID</td>
                            <td class="font-weight-bold">@account.AccountName</td>
                            <td style="color: #475569;">@account.AccountEmail</td>
                            <td>
                                @{
                                    var (roleText, roleClass) = account.AccountRole switch
                                    {
                                        0 => ("Admin", "badge-modern-danger"),
                                        1 => ("Staff", "badge-modern-primary"),
                                        2 => ("Lecturer", "badge-modern-secondary"),
                                        _ => ("Unknown", "badge-modern-secondary")
                                    };
                                }
                                <span class="badge-modern @roleClass">@roleText</span>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn-action-edit"
                                            onclick="openEditModal(@account.AccountID, '@Html.Raw(account.AccountName?.Replace("'","\\'")??"")','@account.AccountEmail','@account.AccountRole')">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </button>
                                    <button type="button" class="btn-action-delete"
                                            onclick="openDeleteModal(@account.AccountID, '@Html.Raw(account.AccountName?.Replace("'","\\'")??"")','@account.AccountEmail')">
                                        <i class="bi bi-trash-fill me-1"></i>Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            var currentPage = (int)(ViewBag.CurrentPage ?? 1);
            var totalPages = (int)(ViewBag.TotalPages ?? 1);
            var startPage = Math.Max(1, currentPage - 2);
            var endPage = Math.Min(totalPages, currentPage + 2);

            <div class="pagination-wrapper">
                <div class="pagination-info">
                    Showing <strong>@(((currentPage - 1) * (int)ViewBag.PageSize) + 1)</strong>
                    to <strong>@Math.Min(currentPage * (int)ViewBag.PageSize, (int)ViewBag.TotalItems)</strong>
                    of <strong>@ViewBag.TotalItems</strong> accounts
                </div>
                <nav aria-label="Accounts pagination">
                    <ul class="pagination pagination-modern mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Accounts" asp-route-page="1" asp-route-searchTerm="@ViewBag.SearchTerm" title="First">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Accounts" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Previous">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="Accounts" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Accounts" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" title="Next">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Accounts" asp-route-page="@totalPages" asp-route-searchTerm="@ViewBag.SearchTerm" title="Last">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- ── Create Account Modal ─────────────────────────────────────────── -->
<div class="modal modal-modern fade" id="createAccountModal" tabindex="-1" aria-labelledby="createAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="CreateAccount" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createAccountModalLabel"><i class="bi bi-person-plus text-danger me-2"></i>Create New Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" name="AccountName" class="form-control-modern w-100" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" name="AccountEmail" class="form-control-modern w-100" required maxlength="70" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" name="AccountPassword" class="form-control-modern w-100" required maxlength="70" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select name="AccountRole" class="form-select-modern w-100" required>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                        <div class="form-text mt-2 text-muted"><i class="bi bi-info-circle me-1"></i>Admin accounts cannot be created here.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-admin-primary">Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Edit Account Modal ────────────────────────────────────────────── -->
<div class="modal modal-modern fade" id="editAccountModal" tabindex="-1" aria-labelledby="editAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editAccountId" name="AccountID" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editAccountModalLabel"><i class="bi bi-pencil-square text-danger me-2"></i>Edit Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" id="editAccountName" name="AccountName" class="form-control-modern w-100" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" id="editAccountEmail" name="AccountEmail" class="form-control-modern w-100" required maxlength="70" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="AccountPassword" class="form-control-modern w-100" maxlength="70"
                               placeholder="Leave blank to keep current password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select id="editAccountRole" name="AccountRole" class="form-select-modern w-100" required>
                            <option value="0">Admin</option>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-admin-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Delete Confirmation Modal ─────────────────────────────────────── -->
<div class="modal modal-modern fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <form asp-action="DeleteAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteAccountId" name="id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteAccountModalLabel" style="color: white;"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-trash-fill text-danger display-4 mb-3 d-block"></i>
                    <h5 class="font-weight-bold text-dark mb-3">Are you sure you want to delete this account?</h5>
                    <div class="p-3 mb-3 border" style="border-radius: 12px; background-color: #f8fafc;">
                        <h6 class="font-weight-bold mb-1" id="deleteAccountName"></h6>
                        <span class="text-muted small" id="deleteAccountEmail"></span>
                    </div>
                    <p class="text-danger font-weight-bold mb-0"><i class="bi bi-info-circle-fill me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-admin-danger">Yes, Delete Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openEditModal(id, name, email, role) {
        document.getElementById('editAccountId').value = id;
        document.getElementById('editAccountName').value = name;
        document.getElementById('editAccountEmail').value = email;
        document.getElementById('editAccountRole').value = role;
        new bootstrap.Modal(document.getElementById('editAccountModal')).show();
    }

    function openDeleteModal(id, name, email) {
        document.getElementById('deleteAccountId').value = id;
        document.getElementById('deleteAccountName').textContent = name;
        document.getElementById('deleteAccountEmail').textContent = email;
        new bootstrap.Modal(document.getElementById('deleteAccountModal')).show();
    }
</script>
}
