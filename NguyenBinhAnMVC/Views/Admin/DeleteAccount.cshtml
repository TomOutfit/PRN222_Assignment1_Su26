@model NguyenBinhAn_A01_Data.Models.SystemAccount
@{
    ViewData["Title"] = "Delete Account";
}

<div class="row">
    <div class="col-md-6">
        <h1>Delete Account</h1>
        
        <div class="alert alert-warning">
            <h3>Are you sure you want to delete this account?</h3>
            <p>This action cannot be undone.</p>
        </div>
        
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Name:</dt>
                    <dd class="col-sm-9">@Model.AccountName</dd>
                    
                    <dt class="col-sm-3">Email:</dt>
                    <dd class="col-sm-9">@Model.AccountEmail</dd>
                    
                    <dt class="col-sm-3">Role:</dt>
                    <dd class="col-sm-9">
                        @{
                            var roleText = Model.AccountRole switch
                            {
                                0 => "Admin",
                                1 => "Staff",
                                2 => "Lecturer",
                                _ => "Unknown"
                            };
                        }
                        <span class="badge bg-@(Model.AccountRole == 0 ? "danger" : Model.AccountRole == 1 ? "primary" : "info")">
                            @roleText
                        </span>
                    </dd>
                </dl>
                
                <form asp-action="DeleteAccountConfirmed" method="post">
                    <input type="hidden" asp-for="AccountID" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Accounts" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
