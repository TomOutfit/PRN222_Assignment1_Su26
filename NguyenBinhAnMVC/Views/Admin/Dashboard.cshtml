@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
        color: white;
        padding: 40px 0;
        margin-bottom: 40px;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }
    
    .dashboard-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }
    
    .dashboard-header h1 {
        font-weight: 700;
        position: relative;
        z-index: 1;
    }
    
    .dashboard-header p {
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }
    
    .dashboard-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        transition: all 0.4s ease;
        overflow: hidden;
        height: 100%;
        position: relative;
    }
    
    .dashboard-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #ff6b6b, #ff8e53);
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }
    
    .dashboard-card:hover::before {
        transform: scaleX(1);
    }
    
    .dashboard-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }
    
    .dashboard-card .card-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 30px;
        color: white;
    }
    
    .dashboard-card .card-title {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 8px;
    }
    
    .dashboard-card .card-text {
        color: #666;
        font-size: 0.9rem;
    }
    
    .dashboard-card .btn {
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 500;
        transition: all 0.3s;
    }
    
    .icon-accounts { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .icon-reports { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .icon-settings { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .icon-analytics { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    
    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }
    
    .stat-card .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }
    
    .stat-card .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    
    .stat-card .stat-label {
        color: #888;
        font-size: 0.9rem;
    }

    .chart-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .chart-card .chart-title {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 20px;
        font-size: 1.1rem;
    }
</style>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-shield-lock me-3"></i>Admin Dashboard</h1>
                <p class="mb-0">Welcome to FUNews Management System Admin Panel. Manage accounts and view system reports.</p>
            </div>
            <div class="col-md-4 text-md-end text-center mt-3 mt-md-0">
                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="stat-number" data-stat="totalAccounts">@ViewBag.TotalAccounts</div>
                    <div class="stat-label">Total Accounts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <div class="stat-number" data-stat="staffCount">@ViewBag.StaffCount</div>
                    <div class="stat-label">Staff Members</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <div>
                    <div class="stat-number" data-stat="lecturerCount">@ViewBag.LecturerCount</div>
                    <div class="stat-label">Lecturers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon me-3" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <i class="bi bi-newspaper"></i>
                </div>
                <div>
                    <div class="stat-number" data-stat="totalNews">@ViewBag.TotalNews</div>
                    <div class="stat-label">Total Articles</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Dashboard Cards -->
<div class="row g-4">
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-accounts">
                    <i class="bi bi-people"></i>
                </div>
                <h5 class="card-title">Account Management</h5>
                <p class="card-text">Manage system accounts, roles, and permissions for all users</p>
                <a asp-action="Accounts" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>Manage Accounts
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-reports">
                    <i class="bi bi-bar-chart"></i>
                </div>
                <h5 class="card-title">Reports</h5>
                <p class="card-text">Generate reports and view detailed statistics about the system</p>
                <a asp-action="Reports" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-2"></i>View Reports
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="card-body text-center p-4">
                <div class="card-icon mx-auto icon-settings">
                    <i class="bi bi-gear"></i>
                </div>
                <h5 class="card-title">System Settings</h5>
                <p class="card-text">Configure system settings and preferences</p>
                <button class="btn btn-secondary" disabled>
                    <i class="bi bi-clock me-2"></i>Coming Soon
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="chart-card">
            <div class="chart-title"><i class="bi bi-pie-chart me-2"></i>Accounts by Role</div>
            <canvas id="accountsByRoleChart" height="220"></canvas>
        </div>
    </div>
    <div class="col-md-8">
        <div class="chart-card">
            <div class="chart-title"><i class="bi bi-bar-chart me-2"></i>News Articles (Last 6 Months)</div>
            <canvas id="newsPerMonthChart" height="110"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let accountsByRoleChart, newsPerMonthChart;

        async function fetchChartData() {
            try {
                const response = await fetch('/Admin/GetChartData');
                if (!response.ok) return;
                const data = await response.json();

                // Doughnut: Accounts by Role
                const roleLabels = Object.keys(data.accountsByRole);
                const roleValues = Object.values(data.accountsByRole);
                const roleColors = ['#667eea', '#f5576c', '#38f9d7', '#ff8e53'];

                if (accountsByRoleChart) {
                    accountsByRoleChart.data.labels = roleLabels;
                    accountsByRoleChart.data.datasets[0].data = roleValues;
                    accountsByRoleChart.data.datasets[0].backgroundColor = roleColors.slice(0, roleLabels.length);
                    accountsByRoleChart.update();
                } else {
                    const ctx = document.getElementById('accountsByRoleChart').getContext('2d');
                    accountsByRoleChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: roleLabels,
                            datasets: [{
                                data: roleValues,
                                backgroundColor: roleColors.slice(0, roleLabels.length),
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { position: 'bottom', labels: { padding: 15, usePointStyle: true } } }
                        }
                    });
                }

                // Bar: News per Month
                const monthLabels = data.newsPerMonth.map(m => m.label);
                const monthCounts = data.newsPerMonth.map(m => m.count);

                if (newsPerMonthChart) {
                    newsPerMonthChart.data.labels = monthLabels;
                    newsPerMonthChart.data.datasets[0].data = monthCounts;
                    newsPerMonthChart.update();
                } else {
                    const ctx2 = document.getElementById('newsPerMonthChart').getContext('2d');
                    newsPerMonthChart = new Chart(ctx2, {
                        type: 'bar',
                        data: {
                            labels: monthLabels,
                            datasets: [{
                                label: 'Articles',
                                data: monthCounts,
                                backgroundColor: 'rgba(102, 126, 234, 0.7)',
                                borderColor: '#667eea',
                                borderWidth: 1,
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, ticks: { stepSize: 1 } }
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Failed to fetch chart data:', e);
            }
        }

        async function fetchStats() {
            try {
                const response = await fetch('/Admin/GetStats');
                if (!response.ok) return;
                const data = await response.json();

                const statMap = {
                    totalAccounts: data.totalAccounts,
                    staffCount: data.staffCount,
                    lecturerCount: data.lecturerCount,
                    totalNews: data.totalNews
                };

                for (const [key, value] of Object.entries(statMap)) {
                    const el = document.querySelector(`[data-stat="${key}"]`);
                    if (el && el.textContent.trim() !== String(value)) {
                        el.textContent = value;
                        el.style.animation = 'none';
                        el.offsetHeight;
                        el.style.animation = 'popIn 0.3s ease';
                    }
                }
            } catch (e) {
                console.error('Failed to fetch stats:', e);
            }
        }

        fetchChartData();
        fetchStats();
        setInterval(fetchChartData, 10000);
        setInterval(fetchStats, 5000);
    </script>
    <style>
        @@keyframes popIn {
            0% { transform: scale(1); }
            50% { transform: scale(1.15); color: #ff6b6b; }
            100% { transform: scale(1); }
        }
    </style>
}
