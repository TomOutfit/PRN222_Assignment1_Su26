@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .dashboard-header {
        background: var(--theme-admin-gradient);
        color: white;
        padding: 50px 0;
        margin-bottom: 35px;
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px var(--theme-admin-glow);
    }

    .dashboard-header::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -5%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }

    .dashboard-header h1 {
        font-weight: 800;
        font-size: 2.6rem;
        letter-spacing: -0.5px;
    }

    .dashboard-header p {
        opacity: 0.9;
        font-weight: 500;
    }

    .stat-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 24px 28px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        display: flex;
        align-items: center;
        gap: 20px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        transition: var(--transition-base);
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 35px rgba(220, 38, 38, 0.05);
        border-color: rgba(220, 38, 38, 0.15);
    }

    .stat-card .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .stat-card .stat-body {
        min-width: 0;
    }

    .stat-card .stat-number {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
        letter-spacing: -0.5px;
    }

    .stat-card .stat-label {
        color: #64748b;
        font-size: 0.88rem;
        font-weight: 600;
        margin-top: 2px;
    }

    .section-label {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 16px;
        padding-left: 4px;
    }

    .chart-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(226, 232, 240, 0.8);
    }

    .chart-card .chart-title {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 25px;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: -0.25px;
    }
</style>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="bi bi-shield-lock me-3"></i>Admin Dashboard</h1>
                <p class="mb-0">System overview — manage accounts, view reports and statistics.</p>
            </div>
            <div class="col-md-4 text-md-end text-center mt-3 mt-md-0">
                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="section-label">System Overview</div>
<div class="row g-4 mb-5">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #4f46e5, #6366f1); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="totalAccounts">@ViewBag.TotalAccounts</div>
                <div class="stat-label">Total Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #ec4899, #f43f5e); box-shadow: 0 4px 12px rgba(236, 72, 153, 0.2);">
                <i class="bi bi-person-badge"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="staffCount">@ViewBag.StaffCount</div>
                <div class="stat-label">Staff Members</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #06b6d4); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                <i class="bi bi-mortarboard"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="lecturerCount">@ViewBag.LecturerCount</div>
                <div class="stat-label">Lecturers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: var(--theme-admin-gradient); box-shadow: 0 4px 12px var(--theme-admin-glow);">
                <i class="bi bi-newspaper"></i>
            </div>
            <div class="stat-body">
                <div class="stat-number" data-stat="totalNews">@ViewBag.TotalNews</div>
                <div class="stat-label">Total Articles</div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="section-label">Analytics</div>
<div class="row g-4">
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-title">
                <i class="bi bi-pie-chart" style="color: #dc2626; font-size: 1.2rem;"></i>
                Accounts by Role
            </div>
            <canvas id="accountsByRoleChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="chart-title">
                <i class="bi bi-bar-chart" style="color: #dc2626; font-size: 1.2rem;"></i>
                News Articles — Last 6 Months
            </div>
            <canvas id="newsPerMonthChart" height="100"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let accountsByRoleChart, newsPerMonthChart;

        async function fetchChartData() {
            try {
                const response = await fetch('/Admin/GetChartData');
                if (!response.ok) return;
                const data = await response.json();

                const roleLabels = Object.keys(data.accountsByRole);
                const roleValues = Object.values(data.accountsByRole);
                const roleColors = ['#dc2626', '#f87171', '#fb7185', '#fda4af'];

                if (accountsByRoleChart) {
                    accountsByRoleChart.data.labels = roleLabels;
                    accountsByRoleChart.data.datasets[0].data = roleValues;
                    accountsByRoleChart.data.datasets[0].backgroundColor = roleColors.slice(0, roleLabels.length);
                    accountsByRoleChart.update();
                } else {
                    const ctx = document.getElementById('accountsByRoleChart').getContext('2d');
                    accountsByRoleChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: roleLabels,
                            datasets: [{
                                data: roleValues,
                                backgroundColor: roleColors.slice(0, roleLabels.length),
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            cutout: '68%',
                            plugins: { 
                                legend: { 
                                    position: 'bottom', 
                                    labels: { 
                                        padding: 20, 
                                        usePointStyle: true, 
                                        font: { size: 12, weight: 'bold' } 
                                    } 
                                } 
                            }
                        }
                    });
                }

                const monthLabels = data.newsPerMonth.map(m => m.label);
                const monthCounts = data.newsPerMonth.map(m => m.count);

                if (newsPerMonthChart) {
                    newsPerMonthChart.data.labels = monthLabels;
                    newsPerMonthChart.data.datasets[0].data = monthCounts;
                    newsPerMonthChart.update();
                } else {
                    const ctx2 = document.getElementById('newsPerMonthChart').getContext('2d');
                    newsPerMonthChart = new Chart(ctx2, {
                        type: 'bar',
                        data: {
                            labels: monthLabels,
                            datasets: [{
                                label: 'Articles',
                                data: monthCounts,
                                backgroundColor: 'rgba(220, 38, 38, 0.75)',
                                borderColor: '#dc2626',
                                borderWidth: 0,
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { 
                                    beginAtZero: true, 
                                    ticks: { stepSize: 1 },
                                    grid: { color: '#f1f5f9' }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Failed to fetch chart data:', e);
            }
        }

        async function fetchStats() {
            try {
                const response = await fetch('/Admin/GetStats');
                if (!response.ok) return;
                const data = await response.json();

                const statMap = {
                    totalAccounts: data.totalAccounts,
                    staffCount: data.staffCount,
                    lecturerCount: data.lecturerCount,
                    totalNews: data.totalNews
                };

                for (const [key, value] of Object.entries(statMap)) {
                    const el = document.querySelector(`[data-stat="${key}"]`);
                    if (el && el.textContent.trim() !== String(value)) {
                        el.textContent = value;
                        el.style.animation = 'none';
                        el.offsetHeight;
                        el.style.animation = 'popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1)';
                    }
                }
            } catch (e) {
                console.error('Failed to fetch stats:', e);
            }
        }

        fetchChartData();
        fetchStats();
        setInterval(fetchChartData, 10000);
        setInterval(fetchStats, 5000);
    </script>
    <style>
        @@keyframes popIn {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); color: #dc2626; }
            100% { transform: scale(1); }
        }
    </style>
}
