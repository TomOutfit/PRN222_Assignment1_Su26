<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNews Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NguyenBinhAnMVC.styles.css" asp-append-version="true" />
    <style>
        * {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        body {
            background-color: var(--bg-global);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Nav link custom underlines */
        .navbar-modern .nav-link {
            position: relative;
            font-weight: 600 !important;
            font-size: 0.95rem;
            color: #475569 !important;
            padding: 0.6rem 1.1rem !important;
        }
        
        .navbar-modern .nav-link:hover,
        .navbar-modern .nav-item.active .nav-link {
            color: #0f172a !important;
        }

        .navbar-modern .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 3px;
            background: var(--theme-public-gradient);
            transition: var(--transition-base);
            border-radius: 3px 3px 0 0;
        }

        .theme-admin .navbar-modern .nav-link::after {
            background: var(--theme-admin-gradient);
        }

        .theme-staff .navbar-modern .nav-link::after {
            background: var(--theme-staff-gradient);
        }
        
        .navbar-modern .nav-link:hover::after {
            width: 60%;
        }

        .user-badge {
            background: var(--theme-public-gradient);
            padding: 6px 16px;
            border-radius: 20px;
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 12px var(--theme-public-glow);
        }

        .theme-admin .user-badge {
            background: var(--theme-admin-gradient);
            box-shadow: 0 4px 12px var(--theme-admin-glow);
        }

        .theme-staff .user-badge {
            background: var(--theme-staff-gradient);
            box-shadow: 0 4px 12px var(--theme-staff-glow);
        }

        /* Modern Footer */
        .footer-modern {
            background: linear-gradient(180deg, #0f172a 0%, #020617 100%);
            color: #94a3b8;
            padding: 70px 0 0;
            margin-top: auto;
            width: 100%;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .footer-modern .footer-brand {
            color: white;
            font-weight: 800;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .footer-modern .footer-brand i {
            font-size: 1.6rem;
            background: var(--theme-public-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .theme-admin .footer-modern .footer-brand i {
            background: var(--theme-admin-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .theme-staff .footer-modern .footer-brand i {
            background: var(--theme-staff-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .footer-modern .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .footer-modern .footer-links li {
            margin-bottom: 12px;
        }
        
        .footer-modern .footer-links a {
            color: #94a3b8;
            text-decoration: none;
            transition: var(--transition-base);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }
        
        .footer-modern .footer-links a:hover {
            color: white;
            transform: translateX(4px);
        }
        
        .footer-modern .footer-links a i {
            color: #6366f1;
            transition: var(--transition-base);
        }

        .theme-admin .footer-modern .footer-links a i {
            color: #f43f5e;
        }

        .theme-staff .footer-modern .footer-links a i {
            color: #10b981;
        }
        
        .footer-modern .footer-divider {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin: 40px 0 0px;
        }
        
        .footer-modern .footer-bottom {
            text-align: center;
            padding: 30px 0;
        }
        
        .footer-modern .footer-bottom p {
            margin: 0;
            font-size: 0.9rem;
            opacity: 0.8;
        }
        
        .footer-modern .footer-bottom a {
            color: #818cf8;
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition-base);
        }
        
        .footer-modern .footer-bottom a:hover {
            color: white;
        }
        
        .footer-modern .social-links {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }
        
        .footer-modern .social-links a {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.03);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            transition: var(--transition-base);
            font-size: 1.1rem;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .footer-modern .social-links a:hover {
            background: var(--theme-public-gradient);
            color: white;
            border-color: transparent;
            transform: translateY(-4px) scale(1.05);
            box-shadow: 0 8px 20px var(--theme-public-glow);
        }

        .theme-admin .footer-modern .social-links a:hover {
            background: var(--theme-admin-gradient);
            box-shadow: 0 8px 20px var(--theme-admin-glow);
        }

        .theme-staff .footer-modern .social-links a:hover {
            background: var(--theme-staff-gradient);
            box-shadow: 0 8px 20px var(--theme-staff-glow);
        }
        
        .footer-section-title {
            color: white;
            font-weight: 700;
            margin-bottom: 20px;
            font-size: 1.05rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
    </style>
</head>
@{
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetInt32("UserRole");
    string roleThemeClass = "";
    if (!string.IsNullOrEmpty(userEmail))
    {
        if (userRole == 0) roleThemeClass = "theme-admin";
        else if (userRole == 1) roleThemeClass = "theme-staff";
        else if (userRole == 2) roleThemeClass = "theme-lecturer";
    }
}
<body class="@roleThemeClass">
    <header>
        <nav class="navbar navbar-expand-sm navbar-modern py-3">
            <div class="container-fluid px-md-4">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-newspaper me-2" style="font-size: 1.5rem;"></i>
                    <span>FUNews</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        @if (string.IsNullOrEmpty(userEmail))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house me-1"></i>Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                    <i class="bi bi-shield-lock me-1"></i>Privacy
                                </a>
                            </li>
                        }
                        else
                        {
                            if (userRole == 0)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-shield-shaded me-1"></i>Admin Panel
                                    </a>
                                    <ul class="dropdown-menu border-0">
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Accounts"><i class="bi bi-people me-2"></i>Manage Accounts</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Reports"><i class="bi bi-bar-chart me-2"></i>Reports</a></li>
                                    </ul>
                                </li>
                            }
                            
                            if (userRole == 1)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="staffDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-briefcase me-1"></i>Staff Panel
                                    </a>
                                    <ul class="dropdown-menu border-0">
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Staff" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Staff" asp-action="Categories"><i class="bi bi-folder me-2"></i>Manage Categories</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Staff" asp-action="News"><i class="bi bi-newspaper me-2"></i>Manage News</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Staff" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile Settings</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Staff" asp-action="NewsHistory"><i class="bi bi-clock-history me-2"></i>News History</a></li>
                                    </ul>
                                </li>
                            }
                            
                            if (userRole == 2)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Lecturer" asp-action="Index">
                                        <i class="bi bi-journals me-1"></i>News Board
                                    </a>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-globe me-1"></i>Public Home
                                </a>
                            </li>
                        }
                    </ul>
                    
                    <ul class="navbar-nav align-items-center">
                        @if (string.IsNullOrEmpty(userEmail))
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary px-4 py-2 border-2 rounded-pill font-weight-bold" asp-area="" asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-badge">
                                        <i class="bi bi-person-circle"></i>
                                        @Context.Session.GetString("UserName")
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0">
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger py-2">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content py-4">
        <div class="container pb-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-modern">
        <div class="container px-md-4">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <i class="bi bi-newspaper"></i>
                        <span>FUNews Management</span>
                    </div>
                    <p class="mb-0" style="font-size: 0.95rem; line-height: 1.6;">
                        A state-of-the-art content management platform for academic communities. Create, categorize, and distribute relevant news with elegance.
                    </p>
                </div>
                <div class="col-lg-2 col-md-4 col-6">
                    <h6 class="footer-section-title">Navigation</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-right"></i>Home</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy"><i class="bi bi-chevron-right"></i>Privacy Policy</a></li>
                        <li><a asp-controller="Auth" asp-action="Login"><i class="bi bi-chevron-right"></i>Portal Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 col-6">
                    <h6 class="footer-section-title">Key Core Modules</h6>
                    <ul class="footer-links">
                        <li><a href="#"><i class="bi bi-chevron-right"></i>News Publisher</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Category Tree System</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Account Control List</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Statistical Reporting</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6 class="footer-section-title">Office & Contacts</h6>
                    <ul class="footer-links">
                        <li><span><i class="bi bi-geo-alt me-2"></i>Can Tho Campus, FPT</span></li>
                        <li><span><i class="bi bi-envelope me-2"></i>funews@fpt.edu.vn</span></li>
                        <li><span><i class="bi bi-telephone me-2"></i>+84 292 730 3636</span></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-divider"></div>
            
            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center">
                <p class="mb-3 mb-md-0">
                    &copy; 2026 <a asp-area="" asp-controller="Home" asp-action="Index">FUNews Portal</a>. All rights reserved.
                </p>
                <div class="social-links mb-0">
                    <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="Linkedin"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
