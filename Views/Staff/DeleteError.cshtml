@model NguyenBinhAn_A01_Data.Models.Category
@{
    ViewData["Title"] = "Cannot Delete Category";
}

<div class="row">
    <div class="col-md-8">
        <div class="alert alert-danger">
            <h4 class="alert-heading">Cannot Delete Category!</h4>
            <p>@ViewBag.ErrorMessage</p>
            <hr>
            <p class="mb-0">This category is currently associated with one or more news articles. Please remove or reassign those articles before deleting this category.</p>
        </div>
        
        <div class="card">
            <div class="card-body">
                <h5>Category Details</h5>
                <dl class="row">
                    <dt class="col-sm-3">Name:</dt>
                    <dd class="col-sm-9">@Model.CategoryName</dd>
                    
                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">@Model.CategoryDescription</dd>
                    
                    <dt class="col-sm-3">Parent Category:</dt>
                    <dd class="col-sm-9">
                        @if (Model.ParentCategoryID.HasValue)
                        {
                            <span>Parent ID: @Model.ParentCategoryID</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                </dl>
                
                <div class="mt-3">
                    <a asp-action="Categories" class="btn btn-secondary">Back to Categories</a>
                    <a asp-action="EditCategory" asp-route-id="@Model.CategoryID" class="btn btn-primary">Edit Category</a>
                </div>
            </div>
        </div>
    </div>
</div>
